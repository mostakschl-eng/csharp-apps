<UserControl x:Class="SCHLStudio.App.Views.ExplorerV2.ExplorerV2View"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:sys="clr-namespace:System;assembly=mscorlib"
             xmlns:vwp="clr-namespace:WpfToolkit.Controls;assembly=VirtualizingWrapPanel"
             mc:Ignorable="d"
             Background="{DynamicResource BgMainBrush}">

    <UserControl.Resources>
        <!-- Shared Sizing and Spacing Tokens -->
        <sys:Double x:Key="ControlHeightLg">38</sys:Double>
        <sys:Double x:Key="ControlHeightMd">34</sys:Double>
        <sys:Double x:Key="ControlHeightSm">32</sys:Double>
        <sys:Double x:Key="TileSize">54</sys:Double>

        <CornerRadius x:Key="RadiusLg">12</CornerRadius>
        <CornerRadius x:Key="RadiusMd">10</CornerRadius>
        <CornerRadius x:Key="RadiusSm">8</CornerRadius>

        <GridLength x:Key="GapLg">10</GridLength>

        <Thickness x:Key="PadBtnX">12,0</Thickness>

        <sys:Double x:Key="FontSizeMd">13</sys:Double>
        <sys:Double x:Key="FontSizeSm">11</sys:Double>
        <sys:Double x:Key="FontSizeXs">12</sys:Double>

        <sys:Double x:Key="MenuMaxHeight">320</sys:Double>
        <sys:Double x:Key="MenuMinWidth">240</sys:Double>

        <Thickness x:Key="PadMenuRoot">6</Thickness>
        <Thickness x:Key="PadMenuItem">8,6</Thickness>
        <Thickness x:Key="PadMenuItemInner">6,4</Thickness>

        <CornerRadius x:Key="RadiusXs">4</CornerRadius>
        <sys:Double x:Key="MenuCheckBoxSize">16</sys:Double>

        <GridLength x:Key="ToggleCheckColumnWidth">18</GridLength>
        <Thickness x:Key="ToggleInnerMargin">10,0</Thickness>
        <GridLength x:Key="MenuCheckColumnWidth">22</GridLength>
        <Style x:Key="SecondaryButtonStyle" TargetType="Button" BasedOn="{StaticResource PrimaryButtonStyle}">
            <Setter Property="Background" Value="{DynamicResource BgCardBrush}"/>
            <Setter Property="Foreground" Value="{DynamicResource TextMainBrush}"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="{DynamicResource BgCardHoverBrush}"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="HeaderButtonStyle" TargetType="Button" BasedOn="{StaticResource SecondaryButtonStyle}">
            <Setter Property="Height" Value="{StaticResource ControlHeightLg}" />
            <Setter Property="Padding" Value="{StaticResource PadBtnX}" />
            <Setter Property="FontSize" Value="{StaticResource FontSizeMd}" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="BorderThickness" Value="0" />
        </Style>

        <Style x:Key="ActionBarButtonStyle" TargetType="Button">
            <Setter Property="Foreground" Value="{DynamicResource TextWhiteBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="BorderBrush" Value="#22000000" />
            <Setter Property="Height" Value="{StaticResource ControlHeightLg}" />
            <Setter Property="Padding" Value="{StaticResource PadBtnX}" />
            <Setter Property="FocusVisualStyle" Value="{x:Null}" />
            <Setter Property="IsTabStop" Value="False" />
            <Setter Property="FontSize" Value="{StaticResource FontSizeSm}" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Grid SnapsToDevicePixels="True">
                            <Border x:Name="Bd"
                                    Background="{TemplateBinding Background}"
                                    BorderBrush="{TemplateBinding BorderBrush}"
                                    BorderThickness="{TemplateBinding BorderThickness}"
                                    CornerRadius="{StaticResource RadiusSm}" />
                            <Border x:Name="Overlay" Background="#FF000000" Opacity="0" CornerRadius="{StaticResource RadiusSm}" />
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Overlay" Property="Opacity" Value="0.06"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Overlay" Property="Opacity" Value="0.14"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.55"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="ContextMenu">
            <Setter Property="Background" Value="{DynamicResource BgCardBrush}" />
            <Setter Property="Foreground" Value="{DynamicResource TextMainBrush}" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="HasDropShadow" Value="False" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ContextMenu">
                        <Border Background="{DynamicResource BgCardBrush}"
                                BorderBrush="{DynamicResource PrimaryBrush}"
                                BorderThickness="1"
                                CornerRadius="{StaticResource RadiusLg}"
                                Padding="{StaticResource PadMenuRoot}">
                            <ScrollViewer VerticalScrollBarVisibility="Auto"
                                          HorizontalScrollBarVisibility="Disabled"
                                          CanContentScroll="True"
                                          MaxHeight="{StaticResource MenuMaxHeight}"
                                          MinWidth="{StaticResource MenuMinWidth}">
                                <ItemsPresenter />
                            </ScrollViewer>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="MenuItem">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="Foreground" Value="{DynamicResource TextMainBrush}" />
            <Setter Property="Padding" Value="{StaticResource PadMenuItem}" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="MenuItem">
                        <Border x:Name="Bd" Background="{TemplateBinding Background}" CornerRadius="{StaticResource RadiusSm}" Padding="{StaticResource PadMenuItemInner}">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="{StaticResource MenuCheckColumnWidth}" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>

                                <Border x:Name="CheckBox"
                                        Grid.Column="0"
                                        Width="{StaticResource MenuCheckBoxSize}"
                                        Height="{StaticResource MenuCheckBoxSize}"
                                        CornerRadius="{StaticResource RadiusXs}"
                                        BorderBrush="{DynamicResource DividerBrush}"
                                        BorderThickness="1"
                                        Background="Transparent"
                                        VerticalAlignment="Center"
                                        HorizontalAlignment="Center">
                                    <TextBlock x:Name="CheckMark"
                                               Text="✓"
                                               FontSize="{StaticResource FontSizeXs}"
                                               FontWeight="Bold"
                                               Foreground="{DynamicResource TextBlackBrush}"
                                               HorizontalAlignment="Center"
                                               VerticalAlignment="Center"
                                               Visibility="Collapsed" />
                                </Border>

                                <ContentPresenter x:Name="HeaderContent"
                                                  Grid.Column="1"
                                                  ContentSource="Header"
                                                  RecognizesAccessKey="True"
                                                  VerticalAlignment="Center"
                                                  Margin="6,0,6,0" />
                            </Grid>
                        </Border>

                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="{DynamicResource BgCardHoverBrush}" />
                            </Trigger>
                            <Trigger Property="IsCheckable" Value="False">
                                <Setter TargetName="CheckBox" Property="Visibility" Value="Collapsed" />
                                <Setter TargetName="HeaderContent" Property="Grid.Column" Value="0" />
                                <Setter TargetName="HeaderContent" Property="Grid.ColumnSpan" Value="2" />
                                <Setter TargetName="HeaderContent" Property="Margin" Value="0,0,6,0" />
                            </Trigger>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="{DynamicResource HoverBrush}" />
                                <Setter TargetName="CheckBox" Property="BorderBrush" Value="{DynamicResource PrimaryBrush}" />
                                <Setter TargetName="CheckBox" Property="Background" Value="{DynamicResource PrimaryBrush}" />
                                <Setter TargetName="CheckMark" Property="Visibility" Value="Visible" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="Bd" Property="Opacity" Value="0.5" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="BreakPlainMenuItemStyle" TargetType="MenuItem">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="Foreground" Value="{DynamicResource TextMainBrush}" />
            <Setter Property="Padding" Value="{StaticResource PadMenuItem}" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="MenuItem">
                        <Border x:Name="Bd" Background="{TemplateBinding Background}" CornerRadius="{StaticResource RadiusSm}" Padding="{StaticResource PadMenuItemInner}">
                            <ContentPresenter ContentSource="Header"
                                              RecognizesAccessKey="True"
                                              VerticalAlignment="Center"
                                              Margin="6,0,6,0" />
                        </Border>

                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="{DynamicResource BgCardHoverBrush}" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="Bd" Property="Opacity" Value="0.5" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="ListView">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="ScrollViewer.Background" Value="Transparent" />
            <Setter Property="ScrollViewer.BorderThickness" Value="0" />
        </Style>

        <Style TargetType="ListViewItem">
            <Setter Property="Padding" Value="0" />
            <Setter Property="Margin" Value="0" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
            <Setter Property="VerticalContentAlignment" Value="Stretch" />
            <Setter Property="FocusVisualStyle" Value="{x:Null}" />
            <Setter Property="OverridesDefaultStyle" Value="True" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ListViewItem">
                        <Border Background="Transparent" Padding="0" Margin="0">
                            <ContentPresenter />
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="FilesFooterToggleButtonStyle" TargetType="ToggleButton">
            <Setter Property="MinWidth" Value="56" />
            <Setter Property="Height" Value="{StaticResource ControlHeightLg}" />
            <Setter Property="Padding" Value="{StaticResource PadBtnX}" />
            <Setter Property="FontSize" Value="13" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="BorderBrush" Value="Transparent" />
            <Setter Property="Background" Value="{DynamicResource BgCardBrush}" />
            <Setter Property="Foreground" Value="{DynamicResource TextMainBrush}" />
            <Setter Property="FocusVisualStyle" Value="{x:Null}" />
            <Setter Property="IsTabStop" Value="False" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ToggleButton">
                        <Grid SnapsToDevicePixels="True">
                            <Border x:Name="Bd"
                                    Background="{TemplateBinding Background}"
                                    BorderBrush="{TemplateBinding BorderBrush}"
                                    BorderThickness="{TemplateBinding BorderThickness}"
                                    CornerRadius="{StaticResource RadiusSm}" />
                            <Border x:Name="Overlay" Background="#FF000000" Opacity="0" CornerRadius="{StaticResource RadiusSm}" />
                            <ContentPresenter Margin="{TemplateBinding Padding}"
                                              HorizontalAlignment="Center"
                                              VerticalAlignment="Center"
                                              RecognizesAccessKey="False">
                                <ContentPresenter.Resources>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="TextTrimming" Value="CharacterEllipsis" />
                                    </Style>
                                </ContentPresenter.Resources>
                            </ContentPresenter>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Overlay" Property="Opacity" Value="0.06" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Overlay" Property="Opacity" Value="0.12" />
                            </Trigger>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="Bd" Property="BorderBrush" Value="{DynamicResource PrimaryBrush}" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.55" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="ListBox">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="ScrollViewer.Background" Value="Transparent" />
            <Setter Property="ScrollViewer.BorderThickness" Value="0" />
        </Style>

        <CollectionViewSource x:Key="FilesTilesGrouped" Source="{Binding FileTiles}">
            <CollectionViewSource.GroupDescriptions>
                <PropertyGroupDescription PropertyName="FolderName" />
            </CollectionViewSource.GroupDescriptions>
        </CollectionViewSource>
    </UserControl.Resources>

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Grid Grid.Row="0" Margin="0,0,0,12" VerticalAlignment="Top">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="{StaticResource GapLg}" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="{StaticResource GapLg}" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="{StaticResource GapLg}" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="{StaticResource GapLg}" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="{StaticResource GapLg}" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0"
                    Width="280"
                    Height="{StaticResource ControlHeightLg}"
                    CornerRadius="{StaticResource RadiusLg}"
                    Background="{DynamicResource BgCardBrush}"
                    BorderBrush="{DynamicResource PrimaryBrush}"
                    BorderThickness="1"
                    Padding="{StaticResource PadBtnX}">
                <Grid>
                    <TextBox x:Name="JlpSearchTextBox"
                             Height="{StaticResource ControlHeightLg}"
                             VerticalContentAlignment="Center"
                             Foreground="{DynamicResource TextMainBrush}"
                             Background="Transparent"
                             BorderThickness="0"
                             Padding="0"
                             FontSize="14"
                             Text=""
                             TextChanged="JlpSearchTextBox_TextChanged" />

                    <TextBlock Text="Search Jobs..."
                               FontSize="14"
                               Foreground="{DynamicResource TextPlaceholderBrush}"
                               VerticalAlignment="Center"
                               IsHitTestVisible="False"
                               Margin="2,0,0,0">
                        <TextBlock.Style>
                            <Style TargetType="TextBlock">
                                <Setter Property="Visibility" Value="Collapsed" />
                                <Style.Triggers>
                                    <MultiDataTrigger>
                                        <MultiDataTrigger.Conditions>
                                            <Condition Binding="{Binding ElementName=JlpSearchTextBox, Path=Text}" Value="" />
                                            <Condition Binding="{Binding ElementName=JlpSearchTextBox, Path=IsKeyboardFocusWithin}" Value="False" />
                                        </MultiDataTrigger.Conditions>
                                        <Setter Property="Visibility" Value="Visible" />
                                    </MultiDataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBlock.Style>
                    </TextBlock>
                </Grid>
            </Border>

            <Button x:Name="JobListButton"
                    Grid.Column="2"
                    Content="Job List"
                    Style="{StaticResource HeaderButtonStyle}"
                    Click="JobListButton_Click" />

            <Button x:Name="WorkTypeButton"
                    Grid.Column="4"
                    Content="{Binding WorkTypeButtonText}"
                    Style="{StaticResource HeaderButtonStyle}"
                    Click="WorkTypeButton_Click">
                <Button.ContextMenu>
                    <ContextMenu x:Name="WorkTypeMenu" Placement="Bottom" />
                </Button.ContextMenu>
            </Button>

            <Border x:Name="TaskControlContainer"
                    Grid.Column="6"
                    Background="{DynamicResource BgCardBrush}"
                    CornerRadius="{StaticResource RadiusLg}"
                    Height="{StaticResource ControlHeightLg}"
                    Padding="0"
                    MouseLeftButtonDown="TaskControlContainer_MouseLeftButtonDown">
                <Grid Height="{StaticResource ControlHeightLg}" VerticalAlignment="Center">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <Button x:Name="TaskButton"
                            Grid.Column="0"
                            Content="Task"
                            Style="{StaticResource HeaderButtonStyle}"
                            Click="TaskButton_Click">
                        <Button.ContextMenu>
                            <ContextMenu x:Name="TaskMenu" Placement="Bottom" />
                        </Button.ContextMenu>
                    </Button>

                    <ScrollViewer Grid.Column="1"
                                  VerticalScrollBarVisibility="Disabled"
                                  HorizontalScrollBarVisibility="Auto"
                                  Background="Transparent"
                                  Margin="6,0,0,0"
                                  Height="{StaticResource ControlHeightLg}">
                        <ItemsControl x:Name="TaskSelectedChips" VerticalAlignment="Center" Height="{StaticResource ControlHeightLg}">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <StackPanel Orientation="Horizontal" />
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding}"
                                               FontSize="12"
                                               Foreground="{DynamicResource TextMainBrush}"
                                               VerticalAlignment="Center"
                                               Margin="0,0,10,0" />
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>
                </Grid>
            </Border>

            <Border Grid.Column="8"
                    Height="{StaticResource ControlHeightLg}"
                    CornerRadius="{StaticResource RadiusLg}"
                    Background="{DynamicResource BgCardBrush}"
                    BorderBrush="{DynamicResource DangerBrush}"
                    BorderThickness="1">
                <Button x:Name="GuidelineButton"
                        Content="Guideline"
                        Style="{StaticResource HeaderButtonStyle}"
                        Background="Transparent"
                        Click="GuidelineButton_Click">
                    <Button.ContextMenu>
                        <ContextMenu x:Name="GuidelineMenu" Placement="Bottom">
                            <ContextMenu.Template>
                                <ControlTemplate TargetType="ContextMenu">
                                    <Border Background="{DynamicResource BgCardBrush}"
                                            BorderBrush="{DynamicResource PrimaryBrush}"
                                            BorderThickness="1"
                                            CornerRadius="{StaticResource RadiusLg}"
                                            Padding="6">
                                        <ScrollViewer VerticalScrollBarVisibility="Auto"
                                                      HorizontalScrollBarVisibility="Disabled"
                                                      CanContentScroll="True"
                                                      MaxHeight="320">
                                            <ItemsPresenter />
                                        </ScrollViewer>
                                    </Border>
                                </ControlTemplate>
                            </ContextMenu.Template>
                        </ContextMenu>
                    </Button.ContextMenu>
                </Button>
            </Border>

            <Border x:Name="TimerBorder"
                    Grid.Column="10"
                    MinWidth="96"
                    Height="{StaticResource ControlHeightLg}"
                    CornerRadius="{StaticResource RadiusLg}"
                    Background="{DynamicResource BgCardBrush}"
                    BorderBrush="{DynamicResource DividerBrush}"
                    BorderThickness="2"
                    Padding="14,0"
                    HorizontalAlignment="Right">
                <TextBlock x:Name="TimerText"
                           Text="{Binding TimerDisplay}"
                           FontSize="16"
                           FontWeight="SemiBold"
                           Foreground="{DynamicResource TextMainBrush}"
                           VerticalAlignment="Center" />
            </Border>
        </Grid>

        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition x:Name="JobListPanelColumn" Width="0" />
                <ColumnDefinition x:Name="JobListDividerColumn" Width="0" />
                <ColumnDefinition Width="3*" />
                <ColumnDefinition Width="{StaticResource GapLg}" />
                <ColumnDefinition Width="1.8*" />
            </Grid.ColumnDefinitions>

            <Border Grid.Column="2"
                    Background="Transparent"
                    BorderThickness="0"
                    CornerRadius="0"
                    Padding="8">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                        <StackPanel Grid.Row="0"
                            Orientation="Horizontal"
                            Margin="0,0,0,10">
                        <TextBlock Text="Files"
                               FontSize="14"
                               FontWeight="SemiBold"
                               Foreground="{DynamicResource TextMainBrush}" />
                        <TextBlock Text="{Binding FileTiles.Count}"
                               FontSize="12"
                               FontWeight="SemiBold"
                               Foreground="{DynamicResource TextSecondaryBrush}"
                               Margin="8,1,0,0" />
                        </StackPanel>

                    <ListView x:Name="FilesListView"
                              Grid.Row="1"
                              Background="Transparent"
                              BorderThickness="0"
                              Foreground="{DynamicResource TextMainBrush}"
                              ScrollViewer.CanContentScroll="True"
                              ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                              VirtualizingPanel.IsVirtualizing="True"
                              VirtualizingPanel.IsVirtualizingWhenGrouping="True"
                              VirtualizingPanel.VirtualizationMode="Recycling"
                              SelectionMode="Extended"
                              ItemsSource="{Binding Source={StaticResource FilesTilesGrouped}}"
                              Padding="2"
                              PreviewMouseLeftButtonDown="FilesListView_PreviewMouseLeftButtonDown"
                              PreviewMouseMove="FilesListView_PreviewMouseMove"
                              PreviewMouseLeftButtonUp="FilesListView_PreviewMouseLeftButtonUp">
                        <ListView.Resources>
                            <Style TargetType="ScrollBar">
                                <Setter Property="Width" Value="10" />
                                <Style.Triggers>
                                    <Trigger Property="Orientation" Value="Vertical">
                                        <Setter Property="Template">
                                            <Setter.Value>
                                                <ControlTemplate TargetType="ScrollBar">
                                                    <Grid Background="Transparent" SnapsToDevicePixels="True">
                                                        <Track x:Name="PART_Track" IsDirectionReversed="True">
                                                            <Track.DecreaseRepeatButton>
                                                                <RepeatButton Command="ScrollBar.LineUpCommand"
                                                                              IsTabStop="False"
                                                                              Height="0"
                                                                              Opacity="0"
                                                                              Focusable="False" />
                                                            </Track.DecreaseRepeatButton>
                                                            <Track.Thumb>
                                                                <Thumb MinHeight="24" IsTabStop="False" Focusable="False">
                                                                    <Thumb.Template>
                                                                        <ControlTemplate TargetType="Thumb">
                                                                            <Border Background="{DynamicResource DividerBrush}"
                                                                                    CornerRadius="6"
                                                                                    Margin="2" />
                                                                        </ControlTemplate>
                                                                    </Thumb.Template>
                                                                </Thumb>
                                                            </Track.Thumb>
                                                            <Track.IncreaseRepeatButton>
                                                                <RepeatButton Command="ScrollBar.LineDownCommand"
                                                                              IsTabStop="False"
                                                                              Height="0"
                                                                              Opacity="0"
                                                                              Focusable="False" />
                                                            </Track.IncreaseRepeatButton>
                                                        </Track>
                                                    </Grid>
                                                </ControlTemplate>
                                            </Setter.Value>
                                        </Setter>
                                    </Trigger>
                                </Style.Triggers>
                            </Style>
                        </ListView.Resources>
                        <ListView.ItemContainerStyle>
                            <Style TargetType="ListViewItem">
                                <Setter Property="FocusVisualStyle" Value="{x:Null}" />
                                <Setter Property="Background" Value="Transparent" />
                                <Setter Property="BorderThickness" Value="0" />
                                <Setter Property="OverridesDefaultStyle" Value="True" />
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="ListViewItem">
                                            <Border Background="Transparent"
                                                    BorderBrush="Transparent"
                                                    BorderThickness="0"
                                                    Padding="{TemplateBinding Padding}"
                                                    SnapsToDevicePixels="True">
                                                <ContentPresenter />
                                            </Border>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                            </Style>
                        </ListView.ItemContainerStyle>

                        <ListView.GroupStyle>
                            <GroupStyle>
                                <GroupStyle.ContainerStyle>
                                    <Style TargetType="GroupItem">
                                        <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                                        <Setter Property="Template">
                                            <Setter.Value>
                                                <ControlTemplate TargetType="GroupItem">
                                                    <Grid>
                                                        <Grid.RowDefinitions>
                                                            <RowDefinition Height="Auto" />
                                                            <RowDefinition Height="Auto" />
                                                        </Grid.RowDefinitions>
                                                        <TextBlock Grid.Row="0"
                                                                   Text="{Binding Name}"
                                                                   VerticalAlignment="Center"
                                                                   FontSize="12"
                                                                   FontWeight="SemiBold"
                                                                   Foreground="{DynamicResource TextMainBrush}"
                                                                   Margin="0,2,0,10" />
                                                        <ItemsPresenter Grid.Row="1" />
                                                    </Grid>
                                                </ControlTemplate>
                                            </Setter.Value>
                                        </Setter>
                                    </Style>
                                </GroupStyle.ContainerStyle>
                                <GroupStyle.Panel>
                                    <ItemsPanelTemplate>
                                        <VirtualizingStackPanel IsItemsHost="True" />
                                    </ItemsPanelTemplate>
                                </GroupStyle.Panel>
                            </GroupStyle>
                        </ListView.GroupStyle>

                        <ListView.ItemsPanel>
                            <ItemsPanelTemplate>
                                <vwp:VirtualizingWrapPanel IsItemsHost="True" Orientation="Horizontal" SpacingMode="None" ItemSize="66,66" />
                            </ItemsPanelTemplate>
                        </ListView.ItemsPanel>
                        <ListView.ItemTemplate>
                            <DataTemplate>
                                <Border x:Name="TileRoot"
                                        Width="{StaticResource TileSize}"
                                        Height="{StaticResource TileSize}"
                                        Background="{DynamicResource BgCardBrush}"
                                        CornerRadius="{StaticResource RadiusLg}"
                                        BorderBrush="{DynamicResource DividerBrush}"
                                        BorderThickness="1"
                                    ToolTip="{Binding FileName}"
                                    ToolTipService.InitialShowDelay="0"
                                        Margin="0,0,12,12">
                                    <TextBlock Text="{Binding Extension}"
                                               HorizontalAlignment="Center"
                                               VerticalAlignment="Center"
                                               FontSize="12"
                                               FontWeight="SemiBold"
                                               Foreground="{DynamicResource TextMainBrush}" />
                                </Border>

                                <DataTemplate.Triggers>
                                    <DataTrigger Binding="{Binding RelativeSource={RelativeSource AncestorType=ListViewItem}, Path=IsSelected}" Value="True">
                                        <Setter TargetName="TileRoot" Property="BorderBrush" Value="{DynamicResource PrimaryBrush}" />
                                        <Setter TargetName="TileRoot" Property="BorderThickness" Value="1" />
                                        <Setter TargetName="TileRoot" Property="Background" Value="{DynamicResource HoverBrush}" />
                                    </DataTrigger>
                                </DataTemplate.Triggers>
                            </DataTemplate>
                        </ListView.ItemTemplate>
                    </ListView>

                    <Grid Grid.Row="2"
                          Margin="0,10,0,0"
                          HorizontalAlignment="Center">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="{StaticResource GapLg}" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>

                        <Border Grid.Column="0"
                                Background="{DynamicResource BgCardBrush}"
                                CornerRadius="{StaticResource RadiusLg}"
                                Padding="12,8"
                                HorizontalAlignment="Center">
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="2,0">
                                <ToggleButton x:Name="FilesWorkButton"
                                              Content="Work"
                                              Style="{StaticResource FilesFooterToggleButtonStyle}"
                                              Checked="FileFilterToggle_Checked"
                                              Margin="0,0,8,0" />
                                <ToggleButton x:Name="FilesProductionDoneButton"
                                              Content="Production Done"
                                              Style="{StaticResource FilesFooterToggleButtonStyle}"
                                              Checked="FileFilterToggle_Checked"
                                              Margin="0,0,8,0" />
                                <ToggleButton x:Name="FilesQc1DoneButton"
                                              Content="QC1 Done"
                                              Style="{StaticResource FilesFooterToggleButtonStyle}"
                                              Checked="FileFilterToggle_Checked"
                                              Margin="0,0,8,0" />
                                <ToggleButton x:Name="FilesQc2DoneButton"
                                              Content="QC2 Done"
                                              Style="{StaticResource FilesFooterToggleButtonStyle}"
                                              Checked="FileFilterToggle_Checked"
                                              Margin="0,0,4,0" />

                                <Border Width="1"
                                        Height="26"
                                        Background="{DynamicResource DividerBrush}"
                                        Margin="6,0,6,0"
                                        VerticalAlignment="Center" />

                                <Button x:Name="ReadyToUploadButton"
                                        Content="Ready To Upload"
                                        Style="{StaticResource HeaderButtonStyle}"
                                        MinWidth="110"
                                        Margin="0,0,0,0"
                                        Command="{Binding ReadyToUploadCommand}" />
                            </StackPanel>
                        </Border>

                        <Button x:Name="ReloadFilesIconButton"
                                Grid.Column="2"
                                Width="34"
                                Height="{StaticResource ControlHeightMd}"
                                Background="Transparent"
                                BorderThickness="0"
                                Padding="0"
                                FocusVisualStyle="{x:Null}"
                                HorizontalAlignment="Center"
                                VerticalAlignment="Center"
                                Click="ReloadFilesButton_Click"
                                RenderTransformOrigin="0.5,0.5">
                            <Button.RenderTransform>
                                <RotateTransform x:Name="ReloadRotate" Angle="0" />
                            </Button.RenderTransform>
                            <Button.Resources>
                                <Storyboard x:Key="ReloadSpin">
                                    <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(RotateTransform.Angle)"
                                                     From="0" To="360" Duration="0:0:0.35" />
                                </Storyboard>
                            </Button.Resources>
                            <Button.Triggers>
                                <EventTrigger RoutedEvent="Button.Click">
                                    <BeginStoryboard Storyboard="{StaticResource ReloadSpin}" />
                                </EventTrigger>
                            </Button.Triggers>
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Border Background="Transparent"
                                            BorderBrush="Transparent"
                                            BorderThickness="0"
                                            SnapsToDevicePixels="True">
                                        <ContentPresenter HorizontalAlignment="Center"
                                                          VerticalAlignment="Center" />
                                    </Border>
                                </ControlTemplate>
                            </Button.Template>
                            <TextBlock Text="&#xE72C;"
                                       FontFamily="Segoe MDL2 Assets"
                                       FontSize="18"
                                       Foreground="{DynamicResource TextMainBrush}"
                                       VerticalAlignment="Center"
                                       HorizontalAlignment="Center" />
                        </Button>
                    </Grid>
                </Grid>
            </Border>

            <Border Grid.Column="3"
                    Width="1"
                    Background="{DynamicResource DividerBrush}"
                    HorizontalAlignment="Center"
                    Margin="0,8" />

            <Border Grid.Column="4"
                    Background="Transparent"
                    BorderThickness="0"
                    CornerRadius="0"
                    Padding="8">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <StackPanel Grid.Row="0" Margin="0,0,0,10">
                        <TextBlock Text="Selected Files"
                                   FontSize="14"
                                   FontWeight="SemiBold"
                                   Foreground="{DynamicResource TextMainBrush}" />

                        <TextBlock x:Name="SelectedFilesMetaText"
                                   Text="{Binding SelectedFilesMetaText}"
                                   FontSize="12"
                                   Foreground="{DynamicResource TextSecondaryBrush}"
                                   Margin="0,4,0,0" />
                    </StackPanel>

                    <ListBox x:Name="SelectedFilesListBox"
                             Grid.Row="1"
                             Background="Transparent"
                             BorderThickness="0"
                             Foreground="{DynamicResource TextMainBrush}"
                             ItemsSource="{Binding SelectedFiles}"
                             SelectionMode="Extended"
                             SelectionChanged="SelectedFilesListBox_SelectionChanged"
                             AllowDrop="True"
                             DragOver="SelectedFilesListBox_DragOver"
                             Drop="SelectedFilesListBox_Drop">
                        <ListBox.ItemContainerStyle>
                            <Style TargetType="ListBoxItem">
                                <Setter Property="Padding" Value="0" />
                                <Setter Property="Margin" Value="0" />
                                <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                                <Setter Property="VerticalContentAlignment" Value="Center" />
                                <Setter Property="FocusVisualStyle" Value="{x:Null}" />
                                <Setter Property="OverridesDefaultStyle" Value="True" />
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="ListBoxItem">
                                            <Border Background="Transparent"
                                                    BorderBrush="Transparent"
                                                    BorderThickness="0"
                                                    SnapsToDevicePixels="True">
                                                <ContentPresenter />
                                            </Border>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                            </Style>
                        </ListBox.ItemContainerStyle>
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <Border x:Name="SelectedRowRoot"
                                        Background="Transparent"
                                        BorderBrush="Transparent"
                                        BorderThickness="1"
                                        CornerRadius="{StaticResource RadiusSm}"
                                        Padding="6"
                                        Margin="0,0,0,8">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto" />
                                            <ColumnDefinition Width="10" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>

                                        <TextBlock Grid.Column="0"
                                                   Text="{Binding Serial}"
                                                   FontSize="12"
                                                   FontWeight="SemiBold"
                                                   Foreground="{DynamicResource TextSecondaryBrush}"
                                                   VerticalAlignment="Center" />

                                        <TextBlock Grid.Column="2"
                                                   Text="{Binding DisplayFileName}"
                                                   FontSize="12"
                                                   Foreground="{DynamicResource TextMainBrush}"
                                                   VerticalAlignment="Center"
                                                   TextTrimming="CharacterEllipsis" />
                                    </Grid>
                                </Border>
                                <DataTemplate.Triggers>
                                    <DataTrigger Binding="{Binding RelativeSource={RelativeSource AncestorType=ListBoxItem}, Path=IsMouseOver}" Value="True">
                                        <Setter TargetName="SelectedRowRoot" Property="BorderBrush" Value="{DynamicResource PrimaryBrush}" />
                                        <Setter TargetName="SelectedRowRoot" Property="BorderThickness" Value="1" />
                                    </DataTrigger>
                                    <DataTrigger Binding="{Binding RelativeSource={RelativeSource AncestorType=ListBoxItem}, Path=IsSelected}" Value="True">
                                        <Setter TargetName="SelectedRowRoot" Property="BorderBrush" Value="{DynamicResource PrimaryBrush}" />
                                        <Setter TargetName="SelectedRowRoot" Property="BorderThickness" Value="1" />
                                    </DataTrigger>
                                </DataTemplate.Triggers>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>

                    <Border Grid.Row="2"
                            Background="{DynamicResource BgCardBrush}"
                            CornerRadius="{StaticResource RadiusLg}"
                            Padding="6"
                            Margin="0,10,0,0"
                            HorizontalAlignment="Center">
                        <StackPanel Orientation="Horizontal"
                                    HorizontalAlignment="Center">

                                <Button x:Name="OpenWithButton"
                                        Content="{Binding OpenWithButtonText}"
                                        Style="{StaticResource HeaderButtonStyle}"
                                        Command="{Binding OpenWithCommand}"
                                        Margin="0,0,4,0">
                                    <Button.ContextMenu>
                                        <ContextMenu x:Name="OpenWithMenu" Placement="Top">
                                            <ContextMenu.Template>
                                            <ControlTemplate TargetType="ContextMenu">
                                                <Border Background="{DynamicResource BgCardBrush}"
                                                        BorderBrush="{DynamicResource PrimaryBrush}"
                                                        BorderThickness="1"
                                                        CornerRadius="{StaticResource RadiusLg}"
                                                        Padding="6"
                                                        SnapsToDevicePixels="True"
                                                        UseLayoutRounding="True"
                                                        ClipToBounds="True"
                                                        RenderOptions.EdgeMode="Aliased">
                                                    <ScrollViewer VerticalScrollBarVisibility="Auto"
                                                                  HorizontalScrollBarVisibility="Disabled"
                                                                  CanContentScroll="True"
                                                                  MaxHeight="320"
                                                                  SnapsToDevicePixels="True">
                                                        <ItemsPresenter />
                                                    </ScrollViewer>
                                                </Border>
                                            </ControlTemplate>
                                        </ContextMenu.Template>
                                        </ContextMenu>
                                    </Button.ContextMenu>
                                </Button>

                                <Button x:Name="StartButton"
                                        Content="{Binding StartButtonText}"
                                        MinWidth="64"
                                        Background="{DynamicResource PrimaryBrush}"
                                        Foreground="{DynamicResource TextBlackBrush}"
                                        Style="{StaticResource ActionBarButtonStyle}"
                                        Command="{Binding StartCommand}"
                                        Margin="0,0,4,0" />

                                <Button x:Name="BreakButton"
                                        Content="Break"
                                        MinWidth="44"
                                        Style="{StaticResource HeaderButtonStyle}"
                                        Command="{Binding BreakCommand}"
                                        Margin="0,0,4,0" />

                                <Button x:Name="FinishButton"
                                        Content="Finish"
                                        MinWidth="44"
                                        Style="{StaticResource HeaderButtonStyle}"
                                        Command="{Binding FinishCommand}"
                                        IsEnabled="{Binding IsFinishEnabled}"
                                        Margin="0,0,4,0" />

                                <Button x:Name="WalkOutButton"
                                        Content="Walk Out"
                                        MinWidth="44"
                                        Style="{StaticResource HeaderButtonStyle}"
                                        Command="{Binding WalkOutCommand}"
                                        IsEnabled="{Binding IsWalkOutEnabled}"
                                        Margin="0,0,4,0" />

                                <Button x:Name="SkipButton"
                                        Content="Skip"
                                        MinWidth="44"
                                        Style="{StaticResource HeaderButtonStyle}"
                                        Command="{Binding SkipCommand}" />
                        </StackPanel>
                    </Border>

                    <Grid x:Name="BusyOverlay"
                          Visibility="{Binding BusyOverlayVisibility}"
                          Background="#66000000"
                          Grid.RowSpan="3"
                          Grid.ColumnSpan="3"
                          Panel.ZIndex="999">
                        <Border Background="{DynamicResource BgCardBrush}"
                                CornerRadius="14"
                                Padding="18"
                                HorizontalAlignment="Center"
                                VerticalAlignment="Center">
                            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                <ProgressBar Width="60" Height="12" IsIndeterminate="True" />
                                <TextBlock x:Name="BusyOverlayText"
                                           Text="{Binding BusyMessage}"
                                           Margin="12,0,0,0"
                                           FontSize="13"
                                           Foreground="{DynamicResource TextWhiteBrush}"
                                           VerticalAlignment="Center" />
                            </StackPanel>
                        </Border>
                    </Grid>
                </Grid>
            </Border>

            <!-- ═══ Job List Inline Panel (toggled by Job List button) ═══ -->
            <Border x:Name="JobListDivider"
                    Grid.Column="1"
                    Width="1"
                    Background="{DynamicResource DividerBrush}"
                    HorizontalAlignment="Center"
                    Margin="0,8"
                    Visibility="Collapsed" />

            <Border x:Name="JobListPanel"
                    Grid.Column="0"
                    Background="Transparent"
                    BorderThickness="0"
                    Padding="8"
                    Visibility="Collapsed">
                <Grid Grid.IsSharedSizeScope="True">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="8" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="8" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <!-- Header row -->
                    <Grid Grid.Row="0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>

                        <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                            <TextBlock Text="Job List"
                                       FontSize="14"
                                       FontWeight="SemiBold"
                                       Foreground="{DynamicResource TextMainBrush}"
                                       VerticalAlignment="Center" />

                            <TextBlock x:Name="JlpCountsText"
                                       Text=""
                                       FontSize="11"
                                       Foreground="{DynamicResource TextSecondaryBrush}"
                                       Margin="8,1,0,0"
                                       VerticalAlignment="Center" />

                            <Button x:Name="JlpReloadButton"
                                    Width="26" Height="26"
                                    Padding="0"
                                    Background="Transparent"
                                    BorderThickness="0"
                                    Margin="6,0,0,0"
                                    Click="JlpReloadButton_Click"
                                    RenderTransformOrigin="0.5,0.5">
                                <Button.RenderTransform>
                                    <RotateTransform Angle="0" />
                                </Button.RenderTransform>
                                <Button.Resources>
                                    <Storyboard x:Key="JlpReloadSpin">
                                        <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(RotateTransform.Angle)"
                                                         From="0" To="360" Duration="0:0:0.35" />
                                    </Storyboard>
                                </Button.Resources>
                                <Button.Triggers>
                                    <EventTrigger RoutedEvent="Button.Click">
                                        <BeginStoryboard Storyboard="{StaticResource JlpReloadSpin}" />
                                    </EventTrigger>
                                </Button.Triggers>
                                <Button.Template>
                                    <ControlTemplate TargetType="Button">
                                        <Border Background="Transparent"><ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" /></Border>
                                    </ControlTemplate>
                                </Button.Template>
                                <TextBlock Text="&#xE72C;"
                                           FontFamily="Segoe MDL2 Assets"
                                           FontSize="14"
                                           Foreground="{DynamicResource TextMainBrush}"
                                           VerticalAlignment="Center"
                                           HorizontalAlignment="Center" />
                            </Button>
                        </StackPanel>

                        <Button Grid.Column="1"
                                Content="✕"
                                Width="28" Height="28"
                                Padding="0"
                                Background="Transparent"
                                Foreground="{DynamicResource TextMainBrush}"
                                BorderThickness="0"
                                Click="JlpCloseButton_Click">
                            <Button.Style>
                                <Style TargetType="Button">
                                    <Setter Property="Cursor" Value="Hand" />
                                    <Style.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter Property="Background" Value="#11000000" />
                                        </Trigger>
                                    </Style.Triggers>
                                </Style>
                            </Button.Style>
                        </Button>
                    </Grid>

                    <!-- Filters row -->
                    <WrapPanel Grid.Row="2" Orientation="Horizontal" VerticalAlignment="Center">
                        <ToggleButton x:Name="JlpRunningButton"  Content="RUNNING"    Height="26" MinWidth="70" Padding="8,0" FontSize="11" Cursor="Hand" Background="{DynamicResource BgCardBrush}" Foreground="{DynamicResource TextMainBrush}" BorderThickness="0" FocusVisualStyle="{x:Null}" Click="JlpStatusButton_Click">
                            <ToggleButton.Template><ControlTemplate TargetType="ToggleButton"><Border x:Name="Bd" Background="{TemplateBinding Background}" CornerRadius="8"><ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" /></Border><ControlTemplate.Triggers><Trigger Property="IsMouseOver" Value="True"><Setter TargetName="Bd" Property="Background" Value="{DynamicResource BgCardHoverBrush}" /></Trigger><Trigger Property="IsChecked" Value="True"><Setter TargetName="Bd" Property="BorderBrush" Value="{DynamicResource PrimaryBrush}" /><Setter TargetName="Bd" Property="BorderThickness" Value="1" /></Trigger></ControlTemplate.Triggers></ControlTemplate></ToggleButton.Template>
                        </ToggleButton>
                        <ToggleButton x:Name="JlpQcButton"         Content="QC"          Height="26" MinWidth="50" Padding="8,0" FontSize="11" Cursor="Hand" Background="{DynamicResource BgCardBrush}" Foreground="{DynamicResource TextMainBrush}" BorderThickness="0" FocusVisualStyle="{x:Null}" Margin="6,0,0,0" Click="JlpStatusButton_Click">
                            <ToggleButton.Template><ControlTemplate TargetType="ToggleButton"><Border x:Name="Bd" Background="{TemplateBinding Background}" CornerRadius="8"><ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" /></Border><ControlTemplate.Triggers><Trigger Property="IsMouseOver" Value="True"><Setter TargetName="Bd" Property="Background" Value="{DynamicResource BgCardHoverBrush}" /></Trigger><Trigger Property="IsChecked" Value="True"><Setter TargetName="Bd" Property="BorderBrush" Value="{DynamicResource PrimaryBrush}" /><Setter TargetName="Bd" Property="BorderThickness" Value="1" /></Trigger></ControlTemplate.Triggers></ControlTemplate></ToggleButton.Template>
                        </ToggleButton>
                        <ToggleButton x:Name="JlpCorrectionButton" Content="CORRECTION"  Height="26" MinWidth="90" Padding="8,0" FontSize="11" Cursor="Hand" Background="{DynamicResource BgCardBrush}" Foreground="{DynamicResource TextMainBrush}" BorderThickness="0" FocusVisualStyle="{x:Null}" Margin="6,0,0,0" Click="JlpStatusButton_Click">
                            <ToggleButton.Template><ControlTemplate TargetType="ToggleButton"><Border x:Name="Bd" Background="{TemplateBinding Background}" CornerRadius="8"><ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" /></Border><ControlTemplate.Triggers><Trigger Property="IsMouseOver" Value="True"><Setter TargetName="Bd" Property="Background" Value="{DynamicResource BgCardHoverBrush}" /></Trigger><Trigger Property="IsChecked" Value="True"><Setter TargetName="Bd" Property="BorderBrush" Value="{DynamicResource PrimaryBrush}" /><Setter TargetName="Bd" Property="BorderThickness" Value="1" /></Trigger></ControlTemplate.Triggers></ControlTemplate></ToggleButton.Template>
                        </ToggleButton>
                        <ToggleButton x:Name="JlpTestButton"       Content="TEST"        Height="26" MinWidth="50" Padding="8,0" FontSize="11" Cursor="Hand" Background="{DynamicResource BgCardBrush}" Foreground="{DynamicResource TextMainBrush}" BorderThickness="0" FocusVisualStyle="{x:Null}" Margin="6,0,0,0" Click="JlpStatusButton_Click">
                            <ToggleButton.Template><ControlTemplate TargetType="ToggleButton"><Border x:Name="Bd" Background="{TemplateBinding Background}" CornerRadius="8"><ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" /></Border><ControlTemplate.Triggers><Trigger Property="IsMouseOver" Value="True"><Setter TargetName="Bd" Property="Background" Value="{DynamicResource BgCardHoverBrush}" /></Trigger><Trigger Property="IsChecked" Value="True"><Setter TargetName="Bd" Property="BorderBrush" Value="{DynamicResource PrimaryBrush}" /><Setter TargetName="Bd" Property="BorderThickness" Value="1" /></Trigger></ControlTemplate.Triggers></ControlTemplate></ToggleButton.Template>
                        </ToggleButton>

                    </WrapPanel>

                    <!-- Job rows list -->
                    <ListView x:Name="JlpJobsList"
                              Grid.Row="4"
                              Background="Transparent"
                              BorderThickness="0"
                              Padding="0"
                              ScrollViewer.VerticalScrollBarVisibility="Hidden"
                              ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                              ScrollViewer.CanContentScroll="False"
                              VirtualizingPanel.IsVirtualizing="True"
                              VirtualizingPanel.VirtualizationMode="Recycling">
                        <ListView.ItemContainerStyle>
                            <Style TargetType="ListViewItem">
                                <Setter Property="Padding" Value="0" />
                                <Setter Property="Margin" Value="0,0,0,5" />
                                <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                                <Setter Property="VerticalContentAlignment" Value="Center" />
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="ListViewItem">
                                            <Border x:Name="RowBd"
                                                    Background="{DynamicResource BgCardBrush}"
                                                    BorderBrush="Transparent"
                                                    BorderThickness="1"
                                                    CornerRadius="10"
                                                    Padding="10,8"
                                                    MinHeight="38"
                                                    SnapsToDevicePixels="True">
                                                <ContentPresenter HorizontalAlignment="Stretch" VerticalAlignment="Stretch" />
                                            </Border>
                                            <ControlTemplate.Triggers>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter TargetName="RowBd" Property="Background" Value="{DynamicResource BgCardHoverBrush}" />
                                                    <Setter TargetName="RowBd" Property="BorderBrush" Value="{DynamicResource PrimaryBrush}" />
                                                </Trigger>
                                                <Trigger Property="IsSelected" Value="True">
                                                    <Setter TargetName="RowBd" Property="Background" Value="{DynamicResource HoverBrush}" />
                                                    <Setter TargetName="RowBd" Property="BorderBrush" Value="{DynamicResource PrimaryBrush}" />
                                                </Trigger>
                                                <DataTrigger Binding="{Binding IsAdded}" Value="True">
                                                    <Setter TargetName="RowBd" Property="BorderBrush" Value="{DynamicResource DangerBrush}" />
                                                </DataTrigger>
                                                <Trigger Property="IsEnabled" Value="False">
                                                    <Setter TargetName="RowBd" Property="Opacity" Value="0.55" />
                                                </Trigger>
                                            </ControlTemplate.Triggers>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                            </Style>
                        </ListView.ItemContainerStyle>
                        <ListView.ItemTemplate>
                            <DataTemplate>
                                <Grid VerticalAlignment="Center">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="26" />
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>

                                    <!-- Toggle add/remove button -->
                                    <Button Grid.Column="0"
                                            Width="22" Height="22"
                                            Padding="0"
                                            Background="Transparent"
                                            BorderThickness="0"
                                            Click="JlpToggleRowButton_Click"
                                            Tag="{Binding}">
                                        <Button.Template>
                                            <ControlTemplate TargetType="Button">
                                                <Border Background="Transparent"><ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" /></Border>
                                            </ControlTemplate>
                                        </Button.Template>
                                        <TextBlock FontFamily="Segoe MDL2 Assets" FontSize="13" VerticalAlignment="Center" TextAlignment="Center">
                                            <TextBlock.Style>
                                                <Style TargetType="TextBlock">
                                                    <Setter Property="Text" Value="&#xEA3A;" />
                                                    <Setter Property="Foreground" Value="{DynamicResource TextSecondaryBrush}" />
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding IsAdded}" Value="True">
                                                            <Setter Property="Text" Value="&#xE73E;" />
                                                            <Setter Property="Foreground" Value="{DynamicResource PrimaryBrush}" />
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </TextBlock.Style>
                                        </TextBlock>
                                    </Button>

                                    <!-- Client + folder stacked -->
                                    <StackPanel Grid.Column="1" VerticalAlignment="Center" Margin="4,0,6,0">
                                        <TextBlock Text="{Binding ClientCode}"
                                                   FontSize="12"
                                                   FontWeight="SemiBold"
                                                   Foreground="{DynamicResource TextMainBrush}"
                                                   TextTrimming="CharacterEllipsis"
                                                   Cursor="Hand"
                                                   MouseLeftButtonDown="JlpClientCodeText_MouseLeftButtonDown" />
                                        <TextBlock Text="{Binding FolderPathShort}"
                                                   ToolTip="{Binding FolderPath}"
                                                   ToolTipService.InitialShowDelay="0"
                                                   FontSize="10"
                                                   Foreground="{DynamicResource TextSecondaryBrush}"
                                                   TextTrimming="CharacterEllipsis"
                                                   Cursor="Hand"
                                                   MouseLeftButtonDown="JlpFolderPathText_MouseLeftButtonDown" />
                                    </StackPanel>

                                    <!-- ET / NOF compact -->
                                    <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center">
                                        <TextBlock FontSize="10" Foreground="{DynamicResource TextSecondaryBrush}" VerticalAlignment="Center">
                                            <Run Text="ET:" /><Run Text="{Binding ET, Mode=OneWay}" />
                                            <Run Text=" NOF:" /><Run Text="{Binding NOF, Mode=OneWay}" />
                                        </TextBlock>
                                        <Button Width="22" Height="22"
                                                Padding="0"
                                                Background="Transparent"
                                                BorderThickness="0"
                                                Cursor="Hand"
                                                Margin="4,0,0,0"
                                                Click="JlpCopyFolderPathButton_Click"
                                                Tag="{Binding}">
                                            <Button.Template>
                                                <ControlTemplate TargetType="Button">
                                                    <Border Background="Transparent"><ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" /></Border>
                                                </ControlTemplate>
                                            </Button.Template>
                                            <TextBlock Text="&#xE8C8;"
                                                       FontFamily="Segoe MDL2 Assets"
                                                       FontSize="12"
                                                       Foreground="{DynamicResource TextSecondaryBrush}"
                                                       VerticalAlignment="Center"
                                                       HorizontalAlignment="Center" />
                                        </Button>
                                    </StackPanel>
                                </Grid>
                            </DataTemplate>
                        </ListView.ItemTemplate>
                    </ListView>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</UserControl>
