<UserControl x:Class="SCHLStudio.App.Views.LiveTracking.Tabs.QcTabView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="Transparent">
    <UserControl.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="/SCHLStudio.App;component/Views/LiveTracking/Shared/LiveTrackingStyles.xaml" />
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </UserControl.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Summary Cards -->
        <Grid Grid.Row="0" Margin="0,6,30,16">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0" Style="{StaticResource LiveCardStyle}" Margin="0,0,10,0">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0">
                        <TextBlock Text="ACTIVE USERS" Style="{StaticResource LiveCardLabelStyle}" />
                        <TextBlock Text="{Binding QcTab.ActiveUsers}" Style="{StaticResource LiveCardValueStyle}" />
                    </StackPanel>
                    <TextBlock Grid.Column="1" Text="&#xE716;" Style="{StaticResource LiveCardIconStyle}" Foreground="#34C759" FontSize="24" Opacity="0.7" Margin="8,0,0,0"/>
                </Grid>
            </Border>

            <Border Grid.Column="1" Style="{StaticResource LiveCardStyle}" Margin="0,0,10,0">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0">
                        <TextBlock Text="TOTAL FILES" Style="{StaticResource LiveCardLabelStyle}" />
                        <TextBlock Text="{Binding QcTab.TotalFiles}" Style="{StaticResource LiveCardValueStyle}" />
                    </StackPanel>
                    <TextBlock Grid.Column="1" Text="&#xE8A5;" Style="{StaticResource LiveCardIconStyle}" Foreground="#007AFF" FontSize="24" Opacity="0.7" Margin="8,0,0,0"/>
                </Grid>
            </Border>

            <Border Grid.Column="2" Style="{StaticResource LiveCardStyle}" Margin="0,0,10,0">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0">
                        <TextBlock Text="COMPLETED" Style="{StaticResource LiveCardLabelStyle}" />
                        <TextBlock Text="{Binding QcTab.CompletedFiles}" Style="{StaticResource LiveCardValueStyle}" />
                    </StackPanel>
                    <TextBlock Grid.Column="1" Text="&#xE73E;" Style="{StaticResource LiveCardIconStyle}" Foreground="#AF52DE" FontSize="24" Opacity="0.7" Margin="8,0,0,0"/>
                </Grid>
            </Border>

            <Border Grid.Column="3" Style="{StaticResource LiveCardStyle}">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0">
                        <TextBlock Text="AVG TIME / FILE" Style="{StaticResource LiveCardLabelStyle}" />
                        <TextBlock Text="{Binding QcTab.AvgTimePerFile}" Style="{StaticResource LiveCardValueStyle}" />
                    </StackPanel>
                    <TextBlock Grid.Column="1" Text="&#xE823;" Style="{StaticResource LiveCardIconStyle}" Foreground="#FF9500" FontSize="24" Opacity="0.7" Margin="8,0,0,0"/>
                </Grid>
            </Border>
        </Grid>

        <!-- Column Headers -->
        <Border Grid.Row="1" Background="{DynamicResource BgCardBrush}" CornerRadius="10" Padding="12,8" Margin="0,0,30,6">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="36"/>
                    <ColumnDefinition Width="1.5*"/>
                    <ColumnDefinition Width="1.2*"/>
                    <ColumnDefinition Width="1*"/>
                    <ColumnDefinition Width="0.7*"/>
                    <ColumnDefinition Width="1.2*"/>
                    <ColumnDefinition Width="0.8*"/>
                    <ColumnDefinition Width="0.8*"/>
                    <ColumnDefinition Width="0.8*"/>
                    <ColumnDefinition Width="0.8*"/>
                    <ColumnDefinition Width="0.8*"/>
                </Grid.ColumnDefinitions>

                <TextBlock Grid.Column="1" Text="EMPLOYEE" Style="{StaticResource LiveGridHeaderTextStyle}" Margin="6,0,0,0" />
                <TextBlock Grid.Column="2" Text="CLIENT" Style="{StaticResource LiveGridHeaderTextStyle}" Margin="6,0,0,0" />
                <TextBlock Grid.Column="3" Text="QC LEVEL" Style="{StaticResource LiveGridHeaderTextStyle}" Margin="6,0,0,0" />
                <TextBlock Grid.Column="4" Text="SHIFT" Style="{StaticResource LiveGridHeaderTextStyle}" HorizontalAlignment="Center" />
                <TextBlock Grid.Column="5" Text="CATEGORIES" Style="{StaticResource LiveGridHeaderTextStyle}" Margin="6,0,0,0" />
                <TextBlock Grid.Column="6" Text="PROGRESS" Style="{StaticResource LiveGridHeaderTextStyle}" HorizontalAlignment="Center" />
                <TextBlock Grid.Column="7" Text="TOTAL TIME" Style="{StaticResource LiveGridHeaderTextStyle}" HorizontalAlignment="Center" />
                <TextBlock Grid.Column="8" Text="AVG / FILE" Style="{StaticResource LiveGridHeaderTextStyle}" HorizontalAlignment="Center" />
                <TextBlock Grid.Column="9" Text="START TIME" Style="{StaticResource LiveGridHeaderTextStyle}" HorizontalAlignment="Center" />
                <TextBlock Grid.Column="10" Text="END TIME" Style="{StaticResource LiveGridHeaderTextStyle}" HorizontalAlignment="Center" />
            </Grid>
        </Border>

        <!-- QC ListView -->
        <ListView Grid.Row="2"
                  ItemsSource="{Binding QcTab.QcRows}"
                  Style="{StaticResource LiveListViewStyle}"
                  ItemContainerStyle="{StaticResource LiveListViewItemStyle}">
            <ListView.ItemTemplate>
                <DataTemplate>
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <Grid Grid.Row="0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="36"/>
                                <ColumnDefinition Width="1.5*"/>
                                <ColumnDefinition Width="1.2*"/>
                                <ColumnDefinition Width="1*"/>
                                <ColumnDefinition Width="0.7*"/>
                                <ColumnDefinition Width="1.2*"/>
                                <ColumnDefinition Width="0.8*"/>
                                <ColumnDefinition Width="0.8*"/>
                                <ColumnDefinition Width="0.8*"/>
                                <ColumnDefinition Width="0.8*"/>
                                <ColumnDefinition Width="0.8*"/>
                            </Grid.ColumnDefinitions>

                            <ToggleButton x:Name="ExpandButton" Grid.Column="0" IsChecked="{Binding IsExpanded, Mode=TwoWay}" Background="Transparent" BorderThickness="0" VerticalAlignment="Center" HorizontalAlignment="Center" Cursor="Hand">
                                <ToggleButton.Style>
                                    <Style TargetType="ToggleButton">
                                        <Setter Property="Template">
                                            <Setter.Value>
                                                <ControlTemplate TargetType="ToggleButton">
                                                    <TextBlock x:Name="Icon" Text="&#xE76C;" FontFamily="Segoe MDL2 Assets" FontSize="12" Foreground="#999999" VerticalAlignment="Center" HorizontalAlignment="Center"/>
                                                    <ControlTemplate.Triggers>
                                                        <Trigger Property="IsChecked" Value="True">
                                                            <Setter TargetName="Icon" Property="Text" Value="&#xE70D;"/>
                                                            <Setter TargetName="Icon" Property="Foreground" Value="{DynamicResource PrimaryBrush}"/>
                                                        </Trigger>
                                                    </ControlTemplate.Triggers>
                                                </ControlTemplate>
                                            </Setter.Value>
                                        </Setter>
                                    </Style>
                                </ToggleButton.Style>
                            </ToggleButton>

                            <TextBlock Grid.Column="1" Text="{Binding EmployeeNameDisplay}" Style="{StaticResource LiveRowBoldTextStyle}" Margin="6,0,10,0"/>
                            <TextBlock Grid.Column="2" Text="{Binding ClientCodeDisplay}" Style="{StaticResource LiveRowTextStyle}" Margin="6,0,10,0"/>
                            <TextBlock Grid.Column="3" Text="{Binding WorkTypeDisplay}" Style="{StaticResource LiveRowTextStyle}" Margin="6,0,10,0"/>
                            <TextBlock Grid.Column="4" Text="{Binding ShiftDisplay}" Style="{StaticResource LiveRowTextStyle}" TextAlignment="Center"/>
                            <TextBlock Grid.Column="5" Text="{Binding CategoriesDisplay}" ToolTip="{Binding Categories}" Style="{StaticResource LiveRowTextStyle}" Margin="6,0,10,0" TextTrimming="CharacterEllipsis"/>
                            <TextBlock Grid.Column="6" Text="{Binding Progress}" Style="{StaticResource LiveRowTextStyle}" TextAlignment="Center" FontWeight="SemiBold" Foreground="{DynamicResource PrimaryBrush}"/>
                            <TextBlock Grid.Column="7" Text="{Binding TotalTimesFormatted}" Style="{StaticResource LiveRowTextStyle}" TextAlignment="Center"/>
                            <TextBlock Grid.Column="8" Text="{Binding AvgTimePerFile}" TextAlignment="Center">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock" BasedOn="{StaticResource LiveRowTextStyle}">
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsOverEstimate}" Value="True">
                                                <Setter Property="Foreground" Value="#E53935"/>
                                                <Setter Property="FontWeight" Value="Bold"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>
                            <TextBlock Grid.Column="9" Text="{Binding StartTimeFormatted}" Style="{StaticResource LiveRowTextStyle}" TextAlignment="Center"/>
                            <TextBlock Grid.Column="10" Text="{Binding EndTimeFormatted}" Style="{StaticResource LiveRowTextStyle}" TextAlignment="Center"/>
                        </Grid>

                        <!-- Expanded File Details -->
                        <Grid Grid.Row="1" Visibility="{Binding IsExpanded, Converter={StaticResource BoolToVis}}" Margin="0,14,0,8">
                            <StackPanel>
                                <Border Height="1" Background="#E0E0E5" Margin="0,0,0,10" />
                                <Border Background="White" CornerRadius="8" BorderBrush="#E5E5EA" BorderThickness="1" Margin="42,0,10,12">
                                    <StackPanel>
                                        <Border Background="#F9F9FB" CornerRadius="8,8,0,0">
                                            <Grid Margin="12,12,12,10">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="3*"/>
                                                    <ColumnDefinition Width="1.2*"/>
                                                    <ColumnDefinition Width="1.2*"/>
                                                    <ColumnDefinition Width="1.2*"/>
                                                    <ColumnDefinition Width="1.2*"/>
                                                    <ColumnDefinition Width="2*"/>
                                                </Grid.ColumnDefinitions>
                                                <TextBlock Grid.Column="0" Text="FILE NAME" Style="{StaticResource LiveGridHeaderTextStyle}"/>
                                                <TextBlock Grid.Column="1" Text="STATUS" Style="{StaticResource LiveGridHeaderTextStyle}"/>
                                                <TextBlock Grid.Column="2" Text="TIME SPENT" Style="{StaticResource LiveGridHeaderTextStyle}"/>
                                                <TextBlock Grid.Column="3" Text="START TIME" Style="{StaticResource LiveGridHeaderTextStyle}"/>
                                                <TextBlock Grid.Column="4" Text="END TIME" Style="{StaticResource LiveGridHeaderTextStyle}"/>
                                                <TextBlock Grid.Column="5" Text="REPORT" Style="{StaticResource LiveGridHeaderTextStyle}"/>
                                            </Grid>
                                        </Border>
                                        <Border Height="1" Background="#E5E5EA" />
                                        <ItemsControl ItemsSource="{Binding Files}">
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate>
                                                    <Border BorderBrush="#E5E5EA" BorderThickness="0,0,0,1" Padding="12,10">
                                                <Grid>
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="3*"/>
                                                        <ColumnDefinition Width="1.2*"/>
                                                        <ColumnDefinition Width="1.2*"/>
                                                        <ColumnDefinition Width="1.2*"/>
                                                        <ColumnDefinition Width="1.2*"/>
                                                        <ColumnDefinition Width="2*"/>
                                                    </Grid.ColumnDefinitions>
                                                    <TextBlock Grid.Column="0" Text="{Binding FileNameDisplay}" ToolTip="{Binding FileName}" Style="{StaticResource LiveFileTextStyle}" TextTrimming="CharacterEllipsis" Margin="0,0,12,0"/>
                                                    <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                                                        <Ellipse Width="7" Height="7" Margin="0,0,6,0" VerticalAlignment="Center">
                                                            <Ellipse.Style>
                                                                <Style TargetType="Ellipse">
                                                                    <Setter Property="Fill" Value="#8E8E93"/>
                                                                    <Style.Triggers>
                                                                        <DataTrigger Binding="{Binding FileStatus}" Value="working"><Setter Property="Fill" Value="#34C759"/></DataTrigger>
                                                                        <DataTrigger Binding="{Binding FileStatus}" Value="done"><Setter Property="Fill" Value="#007AFF"/></DataTrigger>
                                                                        <DataTrigger Binding="{Binding FileStatus}" Value="paused"><Setter Property="Fill" Value="#FF9500"/></DataTrigger>
                                                                    </Style.Triggers>
                                                                </Style>
                                                            </Ellipse.Style>
                                                        </Ellipse>
                                                        <TextBlock Text="{Binding FileStatusDisplay}" Style="{StaticResource LiveFileTextStyle}"/>
                                                    </StackPanel>
                                                    <TextBlock Grid.Column="2" Text="{Binding TimeSpentFormatted}" Style="{StaticResource LiveFileTextStyle}"/>
                                                    <TextBlock Grid.Column="3" Text="{Binding StartTimeFormatted}" Style="{StaticResource LiveFileTextStyle}"/>
                                                    <TextBlock Grid.Column="4" Text="{Binding EndTimeFormatted}" Style="{StaticResource LiveFileTextStyle}"/>
                                                    <TextBlock Grid.Column="5" Text="{Binding Report}" Style="{StaticResource LiveFileTextStyle}" TextTrimming="CharacterEllipsis"/>
                                                </Grid>
                                            </Border>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                                    </StackPanel>
                                </Border>
                            </StackPanel>
                        </Grid>
                    </Grid>
                </DataTemplate>
            </ListView.ItemTemplate>
        </ListView>
    </Grid>
</UserControl>
