<UserControl x:Class="SCHLStudio.App.Views.LiveTracking.Tabs.PauseTabView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="Transparent"
             UseLayoutRounding="True"
             SnapsToDevicePixels="True"
             TextOptions.TextFormattingMode="Display"
             TextOptions.TextRenderingMode="ClearType"
             TextOptions.TextHintingMode="Fixed">
    <UserControl.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="/SCHLStudio.App;component/Views/LiveTracking/Shared/LiveTrackingStyles.xaml" />
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </UserControl.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Summary Cards (icon on right-center, consistent with other tabs) -->
        <Grid Grid.Row="0" Margin="0,6,30,16" UseLayoutRounding="True" SnapsToDevicePixels="True">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0" Style="{StaticResource LiveCardStyle}" Margin="0,0,10,0">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0">
                        <TextBlock Text="PAUSED NOW" Style="{StaticResource LiveCardLabelStyle}" />
                        <TextBlock Text="{Binding PauseTab.TotalPausedUsers}" Style="{StaticResource LiveCardValueStyle}" />
                    </StackPanel>
                    <TextBlock Grid.Column="1" Text="&#xE769;" Style="{StaticResource LiveCardIconStyle}" Foreground="#FF3B30" FontSize="24" Opacity="0.7" Margin="8,0,0,0"/>
                </Grid>
            </Border>

            <Border Grid.Column="1" Style="{StaticResource LiveCardStyle}" Margin="0,0,10,0">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0">
                        <TextBlock Text="WORKING NOW" Style="{StaticResource LiveCardLabelStyle}" />
                        <TextBlock Text="{Binding PauseTab.TotalWorkingUsers}" Style="{StaticResource LiveCardValueStyle}" />
                    </StackPanel>
                    <TextBlock Grid.Column="1" Text="&#xE77B;" Style="{StaticResource LiveCardIconStyle}" Foreground="#34C759" FontSize="24" Opacity="0.7" Margin="8,0,0,0"/>
                </Grid>
            </Border>

            <Border Grid.Column="2" Style="{StaticResource LiveCardStyle}" Margin="0,0,10,0">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0">
                        <TextBlock Text="TOTAL PAUSE" Style="{StaticResource LiveCardLabelStyle}" />
                        <TextBlock Text="{Binding PauseTab.TotalPauseTimeFormatted}" Style="{StaticResource LiveCardValueStyle}" />
                    </StackPanel>
                    <TextBlock Grid.Column="1" Text="&#xE916;" Style="{StaticResource LiveCardIconStyle}" Foreground="#FF9500" FontSize="24" Opacity="0.7" Margin="8,0,0,0"/>
                </Grid>
            </Border>

            <Border Grid.Column="3" Style="{StaticResource LiveCardStyle}">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0">
                        <TextBlock Text="TOTAL WORKING TIME" Style="{StaticResource LiveCardLabelStyle}" />
                        <TextBlock Text="{Binding PauseTab.TotalWorkingTimeFormatted}" Style="{StaticResource LiveCardValueStyle}" />
                    </StackPanel>
                    <TextBlock Grid.Column="1" Text="&#xE823;" Style="{StaticResource LiveCardIconStyle}" Foreground="#007AFF" FontSize="24" Opacity="0.7" Margin="8,0,0,0"/>
                </Grid>
            </Border>
        </Grid>

        <!-- Column Headers -->
        <Border Grid.Row="1" Background="{DynamicResource BgCardBrush}" CornerRadius="10" Padding="12,8" Margin="0,0,30,6">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="36"/>
                    <ColumnDefinition Width="2*"/>
                    <ColumnDefinition Width="1.5*"/>
                    <ColumnDefinition Width="1.5*"/>
                    <ColumnDefinition Width="1.5*"/>
                    <ColumnDefinition Width="1*"/>
                    <ColumnDefinition Width="1*"/>
                    <ColumnDefinition Width="1*"/>
                </Grid.ColumnDefinitions>

                <TextBlock Grid.Column="1" Text="EMPLOYEE" Style="{StaticResource LiveGridHeaderTextStyle}" Margin="6,0,0,0" />
                <TextBlock Grid.Column="2" Text="START TIME" Style="{StaticResource LiveGridHeaderTextStyle}" Margin="0,0,0,0" />
                <TextBlock Grid.Column="3" Text="TOTAL WORK TIME" Style="{StaticResource LiveGridHeaderTextStyle}" HorizontalAlignment="Center"/>
                <TextBlock Grid.Column="4" Text="TOTAL PAUSE" Style="{StaticResource LiveGridHeaderTextStyle}" HorizontalAlignment="Center"/>
                <TextBlock Grid.Column="5" Text="IDLE TIME" Style="{StaticResource LiveGridHeaderTextStyle}" HorizontalAlignment="Center"/>
                <TextBlock Grid.Column="6" Text="PAUSE COUNT" Style="{StaticResource LiveGridHeaderTextStyle}" HorizontalAlignment="Center"/>
                <TextBlock Grid.Column="7" Text="STATUS" Style="{StaticResource LiveGridHeaderTextStyle}" HorizontalAlignment="Center"/>
            </Grid>
        </Border>

        <!-- Pause ListView -->
        <ListView Grid.Row="2"
                  ItemsSource="{Binding PauseTab.PauseGroups}"
                  Style="{StaticResource LiveListViewStyle}"
                  ItemContainerStyle="{StaticResource LiveListViewItemStyle}">
            <ListView.ItemTemplate>
                <DataTemplate>
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <!-- Main Row -->
                        <Grid Grid.Row="0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="36"/>
                                <ColumnDefinition Width="2*"/>
                                <ColumnDefinition Width="1.5*"/>
                                <ColumnDefinition Width="1.5*"/>
                                <ColumnDefinition Width="1.5*"/>
                                <ColumnDefinition Width="1*"/>
                                <ColumnDefinition Width="1*"/>
                                <ColumnDefinition Width="1*"/>
                            </Grid.ColumnDefinitions>

                            <ToggleButton x:Name="ExpandButton" Grid.Column="0" IsChecked="{Binding IsExpanded, Mode=TwoWay}" Background="Transparent" BorderThickness="0" VerticalAlignment="Center" HorizontalAlignment="Center" Cursor="Hand">
                                <ToggleButton.Style>
                                    <Style TargetType="ToggleButton">
                                        <Setter Property="Template">
                                            <Setter.Value>
                                                <ControlTemplate TargetType="ToggleButton">
                                                    <TextBlock x:Name="Icon" Text="&#xE76C;" FontFamily="Segoe MDL2 Assets" FontSize="12" Foreground="#999999" VerticalAlignment="Center" HorizontalAlignment="Center"/>
                                                    <ControlTemplate.Triggers>
                                                        <Trigger Property="IsChecked" Value="True">
                                                            <Setter TargetName="Icon" Property="Text" Value="&#xE70D;"/>
                                                            <Setter TargetName="Icon" Property="Foreground" Value="{DynamicResource PrimaryBrush}"/>
                                                        </Trigger>
                                                    </ControlTemplate.Triggers>
                                                </ControlTemplate>
                                            </Setter.Value>
                                        </Setter>
                                    </Style>
                                </ToggleButton.Style>
                            </ToggleButton>

                            <TextBlock Grid.Column="1" Text="{Binding EmployeeNameDisplay}" Style="{StaticResource LiveRowBoldTextStyle}" Margin="6,0,10,0"/>
                            <TextBlock Grid.Column="2" Text="{Binding FirstLoginFormatted}" Style="{StaticResource LiveRowTextStyle}" Margin="0,0,10,0"/>
                            <TextBlock Grid.Column="3" Text="{Binding TotalWorkTimeFormatted}" Style="{StaticResource LiveRowTextStyle}" TextAlignment="Center" FontWeight="SemiBold" Foreground="#34C759"/>
                            <TextBlock Grid.Column="4" Text="{Binding TotalPauseTimeFormatted}" Style="{StaticResource LiveRowTextStyle}" TextAlignment="Center" FontWeight="SemiBold" Foreground="#FF9500"/>
                            <TextBlock Grid.Column="5" Text="{Binding IdleTimeFormatted}" Style="{StaticResource LiveRowTextStyle}" TextAlignment="Center" Foreground="#FF3B30"/>
                            <TextBlock Grid.Column="6" Text="{Binding PauseCount}" Style="{StaticResource LiveRowTextStyle}" TextAlignment="Center"/>
                            <TextBlock Grid.Column="7" Text="{Binding StatusDisplay}" Style="{StaticResource LiveRowBoldTextStyle}" TextAlignment="Center"/>
                        </Grid>

                        <!-- Expanded Pause Details -->
                        <Grid Grid.Row="1" Visibility="{Binding IsExpanded, Converter={StaticResource BoolToVis}}" Margin="0,14,0,8">
                            <StackPanel>
                                <Border Height="1" Background="#E0E0E5" Margin="0,0,0,10" />

                                <!-- User Session Data Section -->
                                <Border Background="#F9F9FB" CornerRadius="8" Padding="12,8" Margin="42,0,10,12" BorderBrush="#E5E5EA" BorderThickness="1">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <StackPanel Grid.Column="0">
                                            <TextBlock Text="FIRST LOGIN" Style="{StaticResource LiveGridHeaderTextStyle}"/>
                                            <TextBlock Text="{Binding FirstLoginFormatted}" Style="{StaticResource LiveRowBoldTextStyle}" Margin="0,4,0,0" FontSize="14"/>
                                        </StackPanel>
                                        <StackPanel Grid.Column="1">
                                            <TextBlock Text="LAST LOGOUT" Style="{StaticResource LiveGridHeaderTextStyle}"/>
                                            <TextBlock Text="{Binding LastLogoutFormatted}" Style="{StaticResource LiveRowBoldTextStyle}" Margin="0,4,0,0" FontSize="14"/>
                                        </StackPanel>
                                        <StackPanel Grid.Column="2">
                                            <TextBlock Text="TOTAL DURATION TODAY" Style="{StaticResource LiveGridHeaderTextStyle}"/>
                                            <TextBlock Text="{Binding TotalDurationTodayFormatted}" Style="{StaticResource LiveRowBoldTextStyle}" Margin="0,4,0,0" FontSize="14" Foreground="#007AFF"/>
                                        </StackPanel>
                                    </Grid>
                                </Border>

                                <!-- Individual Pauses History Section -->
                                <Border Background="White" CornerRadius="8" BorderBrush="#E5E5EA" BorderThickness="1" Margin="42,0,10,12">
                                    <StackPanel>
                                        <Border Background="#F9F9FB" CornerRadius="8,8,0,0">
                                            <Grid Margin="12,12,12,10">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="2*"/>
                                                    <ColumnDefinition Width="1.5*"/>
                                                    <ColumnDefinition Width="1.5*"/>
                                                    <ColumnDefinition Width="1*"/>
                                                    <ColumnDefinition Width="1*"/>
                                                    <ColumnDefinition Width="1*"/>
                                                    <ColumnDefinition Width="1*"/>
                                                </Grid.ColumnDefinitions>
                                                <TextBlock Grid.Column="0" Text="PAUSE REASON" Style="{StaticResource LiveGridHeaderTextStyle}"/>
                                                <TextBlock Grid.Column="1" Text="CLIENT" Style="{StaticResource LiveGridHeaderTextStyle}"/>
                                                <TextBlock Grid.Column="2" Text="WORK TYPE" Style="{StaticResource LiveGridHeaderTextStyle}"/>
                                                <TextBlock Grid.Column="3" Text="START TIME" Style="{StaticResource LiveGridHeaderTextStyle}"/>
                                                <TextBlock Grid.Column="4" Text="END TIME" Style="{StaticResource LiveGridHeaderTextStyle}"/>
                                                <TextBlock Grid.Column="5" Text="TOTAL PAUSE" Style="{StaticResource LiveGridHeaderTextStyle}"/>
                                                <TextBlock Grid.Column="6" Text="PAUSE COUNT" Style="{StaticResource LiveGridHeaderTextStyle}"/>
                                            </Grid>
                                        </Border>
                                        <Border Height="1" Background="#E5E5EA" />
                                        <ItemsControl ItemsSource="{Binding Pauses}">
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate>
                                                    <Border BorderBrush="#E5E5EA" BorderThickness="0,0,0,1" Padding="12,10">
                                                <Grid>
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="2*"/>
                                                        <ColumnDefinition Width="1.5*"/>
                                                        <ColumnDefinition Width="1.5*"/>
                                                        <ColumnDefinition Width="1*"/>
                                                        <ColumnDefinition Width="1*"/>
                                                        <ColumnDefinition Width="1*"/>
                                                        <ColumnDefinition Width="1*"/>
                                                    </Grid.ColumnDefinitions>
                                                    
                                                    <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center" Margin="0,0,6,0">
                                                        <Ellipse Width="6" Height="6" Fill="#FF9500" Margin="0,0,8,0"/>
                                                        <TextBlock Text="{Binding Reason}" Style="{StaticResource LiveFileTextStyle}" TextTrimming="CharacterEllipsis"/>
                                                    </StackPanel>
                                                    
                                                    <TextBlock Grid.Column="1" Text="{Binding ClientCode}" Style="{StaticResource LiveFileTextStyle}" Margin="0,0,6,0" TextTrimming="CharacterEllipsis"/>
                                                    <TextBlock Grid.Column="2" Text="{Binding WorkType}" Style="{StaticResource LiveFileTextStyle}" Margin="0,0,6,0" TextTrimming="CharacterEllipsis"/>
                                                    <TextBlock Grid.Column="3" Text="{Binding StartTimeFormatted}" Style="{StaticResource LiveFileTextStyle}"/>
                                                    <TextBlock Grid.Column="4" Text="{Binding EndTimeFormatted}" Style="{StaticResource LiveFileTextStyle}"/>
                                                    <TextBlock Grid.Column="5" Text="{Binding DurationFormatted}" Style="{StaticResource LiveFileTextStyle}" Foreground="#FF9500"/>
                                                    <TextBlock Grid.Column="6" Text="{Binding PauseCount}" Style="{StaticResource LiveFileTextStyle}"/>
                                                </Grid>
                                            </Border>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                                    </StackPanel>
                                </Border>
                            </StackPanel>
                        </Grid>
                    </Grid>
                </DataTemplate>
            </ListView.ItemTemplate>
        </ListView>
    </Grid>
</UserControl>
