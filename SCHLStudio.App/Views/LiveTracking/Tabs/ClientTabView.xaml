<UserControl x:Class="SCHLStudio.App.Views.LiveTracking.Tabs.ClientTabView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="Transparent">
    <UserControl.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="/SCHLStudio.App;component/Views/LiveTracking/Shared/LiveTrackingStyles.xaml" />
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </UserControl.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Summary Cards -->
        <Grid Grid.Row="0" Margin="0,6,30,16">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0" Style="{StaticResource LiveCardStyle}" Margin="0,0,10,0">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0">
                        <TextBlock Text="ACTIVE CLIENTS" Style="{StaticResource LiveCardLabelStyle}" />
                        <TextBlock Text="{Binding ClientTab.ActiveClients}" Style="{StaticResource LiveCardValueStyle}" />
                    </StackPanel>
                    <TextBlock Grid.Column="1" Text="&#xE779;" Style="{StaticResource LiveCardIconStyle}" Foreground="#007AFF" FontSize="24" Opacity="0.7" Margin="8,0,0,0"/>
                </Grid>
            </Border>

            <Border Grid.Column="1" Style="{StaticResource LiveCardStyle}" Margin="0,0,10,0">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0">
                        <TextBlock Text="TOTAL EMPLOYEES" Style="{StaticResource LiveCardLabelStyle}" />
                        <TextBlock Text="{Binding ClientTab.TotalEmployees}" Style="{StaticResource LiveCardValueStyle}" />
                    </StackPanel>
                    <TextBlock Grid.Column="1" Text="&#xE716;" Style="{StaticResource LiveCardIconStyle}" Foreground="#34C759" FontSize="24" Opacity="0.7" Margin="8,0,0,0"/>
                </Grid>
            </Border>

            <Border Grid.Column="2" Style="{StaticResource LiveCardStyle}" Margin="0,0,10,0">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0">
                        <TextBlock Text="FILES COMPLETED" Style="{StaticResource LiveCardLabelStyle}" />
                        <TextBlock Text="{Binding ClientTab.FilesCompleted}" Style="{StaticResource LiveCardValueStyle}" />
                    </StackPanel>
                    <TextBlock Grid.Column="1" Text="&#xE8A5;" Style="{StaticResource LiveCardIconStyle}" Foreground="#AF52DE" FontSize="24" Opacity="0.7" Margin="8,0,0,0"/>
                </Grid>
            </Border>

            <Border Grid.Column="3" Style="{StaticResource LiveCardStyle}">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0">
                        <TextBlock Text="TOTAL TIME SPENT" Style="{StaticResource LiveCardLabelStyle}" />
                        <TextBlock Text="{Binding ClientTab.TotalTimeSpent}" Style="{StaticResource LiveCardValueStyle}" />
                    </StackPanel>
                    <TextBlock Grid.Column="1" Text="&#xE823;" Style="{StaticResource LiveCardIconStyle}" Foreground="#FF9500" FontSize="24" Opacity="0.7" Margin="8,0,0,0"/>
                </Grid>
            </Border>
        </Grid>

        <!-- Column Headers -->
        <Border Grid.Row="1" Background="{DynamicResource BgCardBrush}" CornerRadius="10" Padding="12,8" Margin="0,0,30,6">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="1.7*"/>
                    <ColumnDefinition Width="1.5*"/>
                    <ColumnDefinition Width="1.2*"/>
                    <ColumnDefinition Width="0.8*"/>
                    <ColumnDefinition Width="0.8*"/>
                    <ColumnDefinition Width="0.8*"/>
                    <ColumnDefinition Width="0.8*"/>
                    <ColumnDefinition Width="0.8*"/>
                    <ColumnDefinition Width="0.8*"/>
                    <ColumnDefinition Width="0.8*"/>
                </Grid.ColumnDefinitions>

                <TextBlock Grid.Column="0" Text="CLIENT" Style="{StaticResource LiveGridHeaderTextStyle}" Margin="6,0,0,0"/>
                <TextBlock Grid.Column="1" Text="EMPLOYEES" Style="{StaticResource LiveGridHeaderTextStyle}" HorizontalAlignment="Center"/>
                <TextBlock Grid.Column="2" Text="CATEGORIES" Style="{StaticResource LiveGridHeaderTextStyle}" Margin="6,0,0,0"/>
                <TextBlock Grid.Column="3" Text="PROD DONE" Style="{StaticResource LiveGridHeaderTextStyle}" HorizontalAlignment="Center"/>
                <TextBlock Grid.Column="4" Text="QC DONE" Style="{StaticResource LiveGridHeaderTextStyle}" HorizontalAlignment="Center"/>
                <TextBlock Grid.Column="5" Text="ET TIME" Style="{StaticResource LiveGridHeaderTextStyle}" HorizontalAlignment="Center"/>
                <TextBlock Grid.Column="6" Text="TOTAL TIME" Style="{StaticResource LiveGridHeaderTextStyle}" HorizontalAlignment="Center"/>
                <TextBlock Grid.Column="7" Text="AVG TIME" Style="{StaticResource LiveGridHeaderTextStyle}" HorizontalAlignment="Center"/>
                <TextBlock Grid.Column="8" Text="START TIME" Style="{StaticResource LiveGridHeaderTextStyle}" HorizontalAlignment="Center"/>
                <TextBlock Grid.Column="9" Text="END TIME" Style="{StaticResource LiveGridHeaderTextStyle}" HorizontalAlignment="Center"/>
            </Grid>
        </Border>

        <!-- Client Lists -->
        <ScrollViewer Grid.Row="2" VerticalScrollBarVisibility="Auto">
            <StackPanel Margin="0,0,10,0">
                <!-- Working Section -->
                <TextBlock Text="WORKING CLIENTS" Style="{StaticResource LiveCardLabelStyle}" Foreground="#34C759" Margin="6,0,0,10" />
                <ListView ItemsSource="{Binding ClientTab.WorkingClients}"
                          Style="{StaticResource LiveListViewStyle}"
                          ItemContainerStyle="{StaticResource LiveListViewItemStyle}"
                          Margin="0,0,0,20">
                    <ListView.ItemTemplate>
                        <DataTemplate>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="1.7*"/>
                                    <ColumnDefinition Width="1.5*"/>
                                    <ColumnDefinition Width="1.2*"/>
                                    <ColumnDefinition Width="0.8*"/>
                                    <ColumnDefinition Width="0.8*"/>
                                    <ColumnDefinition Width="0.8*"/>
                                    <ColumnDefinition Width="0.8*"/>
                                    <ColumnDefinition Width="0.8*"/>
                                    <ColumnDefinition Width="0.8*"/>
                                    <ColumnDefinition Width="0.8*"/>
                                </Grid.ColumnDefinitions>

                                <StackPanel Grid.Column="0" Orientation="Horizontal">
                                    <Ellipse Width="8" Height="8" Fill="#34C759" Margin="0,0,8,0" VerticalAlignment="Center" />
                                    <TextBlock Text="{Binding ClientNameDisplay}" Style="{StaticResource LiveRowBoldTextStyle}" VerticalAlignment="Center"/>
                                </StackPanel>
                                <TextBlock Grid.Column="1" Text="{Binding ActiveEmployees}" Style="{StaticResource LiveRowTextStyle}" TextAlignment="Center"/>
                                <TextBlock Grid.Column="2" Text="{Binding CategoriesDisplay}" ToolTip="{Binding Categories}" Style="{StaticResource LiveRowTextStyle}" Margin="6,0,10,0" TextTrimming="CharacterEllipsis"/>
                                <TextBlock Grid.Column="3" Text="{Binding TotalProductionFilesDone}" Style="{StaticResource LiveRowTextStyle}" TextAlignment="Center"/>
                                <TextBlock Grid.Column="4" Text="{Binding TotalQcFilesDone}" Style="{StaticResource LiveRowTextStyle}" TextAlignment="Center"/>
                                <TextBlock Grid.Column="5" Text="{Binding EstimateTimeFormatted}" Style="{StaticResource LiveRowTextStyle}" TextAlignment="Center"/>
                                <TextBlock Grid.Column="6" Text="{Binding TotalTimeSpentFormatted}" Style="{StaticResource LiveRowTextStyle}" TextAlignment="Center"/>
                                <TextBlock Grid.Column="7" Text="{Binding AvgTimeFormatted}" Style="{StaticResource LiveRowTextStyle}" TextAlignment="Center"/>
                                <TextBlock Grid.Column="8" Text="{Binding StartTimeFormatted}" Style="{StaticResource LiveRowTextStyle}" TextAlignment="Center"/>
                                <TextBlock Grid.Column="9" Text="{Binding EndTimeFormatted}" Style="{StaticResource LiveRowTextStyle}" TextAlignment="Center"/>
                            </Grid>
                        </DataTemplate>
                    </ListView.ItemTemplate>
                </ListView>

                <!-- Idle Section -->
                <TextBlock Text="NOT WORKING CLIENTS" Style="{StaticResource LiveCardLabelStyle}" Opacity="0.6" Margin="6,0,0,10" />
                <ListView ItemsSource="{Binding ClientTab.InactiveClients}"
                          Style="{StaticResource LiveListViewStyle}"
                          ItemContainerStyle="{StaticResource LiveListViewItemStyle}">
                    <ListView.ItemTemplate>
                        <DataTemplate>
                            <Grid Opacity="0.7">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="1.7*"/>
                                    <ColumnDefinition Width="1.5*"/>
                                    <ColumnDefinition Width="1.2*"/>
                                    <ColumnDefinition Width="0.8*"/>
                                    <ColumnDefinition Width="0.8*"/>
                                    <ColumnDefinition Width="0.8*"/>
                                    <ColumnDefinition Width="0.8*"/>
                                    <ColumnDefinition Width="0.8*"/>
                                    <ColumnDefinition Width="0.8*"/>
                                    <ColumnDefinition Width="0.8*"/>
                                </Grid.ColumnDefinitions>

                                <TextBlock Grid.Column="0" Text="{Binding ClientNameDisplay}" Style="{StaticResource LiveRowBoldTextStyle}" Margin="16,0,10,0"/>
                                <TextBlock Grid.Column="1" Text="{Binding ActiveEmployees}" Style="{StaticResource LiveRowTextStyle}" TextAlignment="Center"/>
                                <TextBlock Grid.Column="2" Text="{Binding CategoriesDisplay}" ToolTip="{Binding Categories}" Style="{StaticResource LiveRowTextStyle}" Margin="6,0,10,0" TextTrimming="CharacterEllipsis"/>
                                <TextBlock Grid.Column="3" Text="{Binding TotalProductionFilesDone}" Style="{StaticResource LiveRowTextStyle}" TextAlignment="Center"/>
                                <TextBlock Grid.Column="4" Text="{Binding TotalQcFilesDone}" Style="{StaticResource LiveRowTextStyle}" TextAlignment="Center"/>
                                <TextBlock Grid.Column="5" Text="{Binding EstimateTimeFormatted}" Style="{StaticResource LiveRowTextStyle}" TextAlignment="Center"/>
                                <TextBlock Grid.Column="6" Text="{Binding TotalTimeSpentFormatted}" Style="{StaticResource LiveRowTextStyle}" TextAlignment="Center"/>
                                <TextBlock Grid.Column="7" Text="{Binding AvgTimeFormatted}" Style="{StaticResource LiveRowTextStyle}" TextAlignment="Center"/>
                                <TextBlock Grid.Column="8" Text="{Binding StartTimeFormatted}" Style="{StaticResource LiveRowTextStyle}" TextAlignment="Center"/>
                                <TextBlock Grid.Column="9" Text="{Binding EndTimeFormatted}" Style="{StaticResource LiveRowTextStyle}" TextAlignment="Center"/>
                            </Grid>
                        </DataTemplate>
                    </ListView.ItemTemplate>
                </ListView>
            </StackPanel>
        </ScrollViewer>
    </Grid>
</UserControl>
