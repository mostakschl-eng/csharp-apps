<UserControl x:Class="SCHLStudio.App.Views.LiveTracking.Tabs.ProductivityTabView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:converters="clr-namespace:SCHLStudio.App.Shared.Converters"
             Background="Transparent"
             UseLayoutRounding="True"
             SnapsToDevicePixels="True"
             TextOptions.TextFormattingMode="Display"
             TextOptions.TextRenderingMode="ClearType">
    <UserControl.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="/SCHLStudio.App;component/Views/LiveTracking/Shared/LiveTrackingStyles.xaml" />
            </ResourceDictionary.MergedDictionaries>

            <converters:AlternationIndexToOneBasedConverter x:Key="AlternationIndexToOneBasedConverter" />
        </ResourceDictionary>
    </UserControl.Resources>

    <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled" Padding="0,0,12,0" Margin="0,0,6,0">
        <StackPanel>
            <!-- Summary Cards (icon on right-center) -->
            <Grid Margin="0,6,0,12">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <Border Grid.Column="0" Style="{StaticResource LiveCardStyle}" Margin="0,0,10,0">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0">
                            <TextBlock Text="TOTAL FILES" Style="{StaticResource LiveCardLabelStyle}" />
                            <TextBlock Text="{Binding ProductivityTab.TotalFiles}" Style="{StaticResource LiveCardValueStyle}" />
                        </StackPanel>
                        <TextBlock Grid.Column="1" Text="&#xE8A5;" Style="{StaticResource LiveCardIconStyle}" Foreground="#007AFF" FontSize="24" Opacity="0.7" Margin="8,0,0,0"/>
                    </Grid>
                </Border>

                <Border Grid.Column="1" Style="{StaticResource LiveCardStyle}" Margin="0,0,10,0">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0">
                            <TextBlock Text="TOTAL USERS" Style="{StaticResource LiveCardLabelStyle}" />
                            <TextBlock Text="{Binding ProductivityTab.TotalUsers}" Style="{StaticResource LiveCardValueStyle}" />
                        </StackPanel>
                        <TextBlock Grid.Column="1" Text="&#xE716;" Style="{StaticResource LiveCardIconStyle}" Foreground="#34C759" FontSize="24" Opacity="0.7" Margin="8,0,0,0"/>
                    </Grid>
                </Border>

                <Border Grid.Column="2" Style="{StaticResource LiveCardStyle}" Margin="0,0,10,0">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0">
                            <TextBlock Text="COMPLETED FILES" Style="{StaticResource LiveCardLabelStyle}" />
                            <TextBlock Text="{Binding ProductivityTab.CompletedFiles}" Style="{StaticResource LiveCardValueStyle}" />
                        </StackPanel>
                        <TextBlock Grid.Column="1" Text="&#xE73E;" Style="{StaticResource LiveCardIconStyle}" Foreground="#AF52DE" FontSize="24" Opacity="0.7" Margin="8,0,0,0"/>
                    </Grid>
                </Border>

                <Border Grid.Column="3" Style="{StaticResource LiveCardStyle}">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0">
                            <TextBlock Text="AVG TIME / FILE" Style="{StaticResource LiveCardLabelStyle}" />
                            <TextBlock Text="{Binding ProductivityTab.AvgTimePerFile}" Style="{StaticResource LiveCardValueStyle}" />
                        </StackPanel>
                        <TextBlock Grid.Column="1" Text="&#xE823;" Style="{StaticResource LiveCardIconStyle}" Foreground="#FF9500" FontSize="24" Opacity="0.7" Margin="8,0,0,0"/>
                    </Grid>
                </Border>
            </Grid>

            <!-- Search bar + Filter button -->
            <Grid Margin="0,0,0,12" HorizontalAlignment="Left" MaxWidth="300">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="240"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <Border Grid.Column="0" CornerRadius="8" Background="#F5F6F8" BorderBrush="#E0E0E5" BorderThickness="1" Padding="2,0" Margin="0,0,6,0">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="&#xE721;" FontFamily="Segoe MDL2 Assets" FontSize="12"
                                   Foreground="#AAAAAA" VerticalAlignment="Center" Margin="6,0,4,0"/>
                        <TextBox Grid.Column="1"
                                 Text="{Binding ProductivityTab.SearchText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                 Background="Transparent" BorderThickness="0"
                                 FontFamily="{StaticResource MainFontFamily}" FontSize="12"
                                 Foreground="{DynamicResource TextMainBrush}"
                                 Padding="4,6" VerticalAlignment="Center"/>
                    </Grid>
                </Border>

                <!-- Filter button -->
                <ToggleButton x:Name="ProdFilterToggle" Grid.Column="1" Background="Transparent" BorderThickness="0" Cursor="Hand" VerticalAlignment="Center">
                    <ToggleButton.Template>
                        <ControlTemplate TargetType="ToggleButton">
                            <Border x:Name="Bd" Background="{DynamicResource BgCardBrush}" BorderBrush="{DynamicResource BorderLightBrush}" BorderThickness="1" CornerRadius="8" Padding="6,5" Cursor="Hand">
                                <TextBlock Text="&#xE71C;" FontFamily="Segoe MDL2 Assets" FontSize="13" Foreground="{DynamicResource PrimaryBrush}" VerticalAlignment="Center"/>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsChecked" Value="True">
                                    <Setter TargetName="Bd" Property="BorderBrush" Value="{DynamicResource PrimaryBrush}"/>
                                    <Setter TargetName="Bd" Property="Background" Value="#E8F0FE"/>
                                </Trigger>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="Bd" Property="Background" Value="#F0F4FF"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </ToggleButton.Template>
                </ToggleButton>

                <!-- Filter Popup -->
                <Popup IsOpen="{Binding IsChecked, ElementName=ProdFilterToggle}" StaysOpen="False" Placement="Bottom" PlacementTarget="{Binding ElementName=ProdFilterToggle}" HorizontalOffset="-180" VerticalOffset="4" AllowsTransparency="True">
                    <Border Background="White" CornerRadius="10" BorderBrush="#E0E0E5" BorderThickness="1" Padding="14" MinWidth="240">
                        <Border.Effect>
                            <DropShadowEffect BlurRadius="12" Opacity="0.15" ShadowDepth="4" Direction="270"/>
                        </Border.Effect>
                        <StackPanel>
                            <TextBlock Text="Date Filter" FontFamily="{StaticResource MainFontFamily}" FontSize="13" FontWeight="SemiBold" Foreground="{DynamicResource TextMainBrush}" Margin="0,0,0,10"/>

                            <TextBlock Text="FROM" FontFamily="{StaticResource MainFontFamily}" FontSize="10" FontWeight="SemiBold" Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,0,0,4"/>
                            <DatePicker SelectedDate="{Binding ProductivityTab.FilterDateFrom, Mode=TwoWay}" Width="200" Height="30" FontFamily="{StaticResource MainFontFamily}" FontSize="12" Margin="0,0,0,10"/>

                            <TextBlock Text="TO" FontFamily="{StaticResource MainFontFamily}" FontSize="10" FontWeight="SemiBold" Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,0,0,4"/>
                            <DatePicker SelectedDate="{Binding ProductivityTab.FilterDateTo, Mode=TwoWay}" Width="200" Height="30" FontFamily="{StaticResource MainFontFamily}" FontSize="12" Margin="0,0,0,12"/>

                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                                <Button Content="Clear" Command="{Binding ProductivityTab.ClearFilterCommand}" Background="Transparent" Foreground="{DynamicResource TextSecondaryBrush}" BorderThickness="0" FontSize="11" FontFamily="{StaticResource MainFontFamily}" Padding="8,4" Cursor="Hand" Margin="0,0,6,0"/>
                                <Button Content="Apply" Command="{Binding ProductivityTab.ApplyFilterCommand}" Style="{StaticResource PrimaryButtonStyle}" MinWidth="60" Height="28" FontSize="11" FontFamily="{StaticResource MainFontFamily}" Padding="10,2" Cursor="Hand"/>
                            </StackPanel>
                        </StackPanel>
                    </Border>
                </Popup>
            </Grid>

            <!-- Two-Panel Layout: Employees + QC Team -->
            <Grid Margin="0,0,0,20">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="14"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- EMPLOYEES Section -->
                <StackPanel Grid.Column="0">
                    <!-- Section Header -->
                    <Grid Margin="0,0,0,12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0" Orientation="Horizontal">
                            <TextBlock Text="&#xE716;" FontFamily="Segoe MDL2 Assets" FontSize="16" Foreground="#007AFF" VerticalAlignment="Center" Margin="0,0,8,0"/>
                            <TextBlock Text="EMPLOYEES" Style="{StaticResource LiveSectionTitleStyle}"/>
                        </StackPanel>
                        <Border Grid.Column="2" Background="#EBF5FF" CornerRadius="6" Padding="8,4">
                            <TextBlock Text="Top Performers" Style="{StaticResource LiveSectionBadgeStyle}" Foreground="#007AFF"/>
                        </Border>
                    </Grid>

                    <!-- Each category = separate card box -->
                    <ItemsControl ItemsSource="{Binding ProductivityTab.EmployeeCategoryGroups}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Background="{DynamicResource BgCardBrush}" CornerRadius="10" Padding="14,12" Margin="0,0,0,10" SnapsToDevicePixels="True">
                                    <Border.Effect>
                                        <DropShadowEffect ShadowDepth="1" BlurRadius="4" Opacity="0.06" Color="#000000"/>
                                    </Border.Effect>
                                    <StackPanel>
                                        <!-- Category name header -->
                                        <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                                            <Ellipse Width="8" Height="8" Fill="#007AFF" VerticalAlignment="Center" Margin="0,0,8,0"/>
                                            <TextBlock Text="{Binding CategoryDisplay}" Style="{StaticResource LiveCategoryNameStyle}"/>
                                        </StackPanel>

                                        <!-- Column headers -->
                                        <Grid Margin="4,0,0,4">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="34"/>
                                                <ColumnDefinition Width="2.2*"/>
                                                <ColumnDefinition Width="0.8*"/>
                                                <ColumnDefinition Width="1.2*"/>
                                                <ColumnDefinition Width="1*"/>
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Grid.Column="0" Text="#" Style="{StaticResource LiveGridHeaderTextStyle}" TextAlignment="Center"/>
                                            <TextBlock Grid.Column="1" Text="EMPLOYEE" Style="{StaticResource LiveGridHeaderTextStyle}"/>
                                            <TextBlock Grid.Column="2" Text="FILES" Style="{StaticResource LiveGridHeaderTextStyle}" TextAlignment="Center"/>
                                            <TextBlock Grid.Column="3" Text="TOTAL TIME" Style="{StaticResource LiveGridHeaderTextStyle}" TextAlignment="Center"/>
                                            <TextBlock Grid.Column="4" Text="AVG TIME" Style="{StaticResource LiveGridHeaderTextStyle}" TextAlignment="Center"/>
                                        </Grid>

                                        <!-- Employee rows (ranked: most files first) -->
                                        <ItemsControl ItemsSource="{Binding Employees}" AlternationCount="1000000">
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate>
                                                    <Border Padding="4,7" BorderBrush="Transparent" BorderThickness="1" CornerRadius="6" Background="Transparent" Margin="0,1,0,0">
                                                        <Border.Style>
                                                            <Style TargetType="Border">
                                                                <Style.Triggers>
                                                                    <Trigger Property="IsMouseOver" Value="True">
                                                                        <Setter Property="BorderBrush" Value="{DynamicResource PrimaryBrush}"/>
                                                                    </Trigger>
                                                                </Style.Triggers>
                                                            </Style>
                                                        </Border.Style>
                                                        <Grid>
                                                            <Grid.ColumnDefinitions>
                                                                <ColumnDefinition Width="34"/>
                                                                <ColumnDefinition Width="2.2*"/>
                                                                <ColumnDefinition Width="0.8*"/>
                                                                <ColumnDefinition Width="1.2*"/>
                                                                <ColumnDefinition Width="1*"/>
                                                            </Grid.ColumnDefinitions>
                                                            <TextBlock Grid.Column="0" TextAlignment="Center" Style="{StaticResource LiveRowTextStyle}" Foreground="{DynamicResource TextSecondaryBrush}"
                                                                       Text="{Binding RelativeSource={RelativeSource AncestorType=ContentPresenter}, Path=(ItemsControl.AlternationIndex), Converter={StaticResource AlternationIndexToOneBasedConverter}}"/>
                                                            <TextBlock Grid.Column="1" Text="{Binding EmployeeNameDisplay}" Style="{StaticResource LiveRowBoldTextStyle}"/>
                                                            <TextBlock Grid.Column="2" Text="{Binding TotalFiles}" Style="{StaticResource LiveRowTextStyle}" TextAlignment="Center" FontWeight="SemiBold" Foreground="{DynamicResource PrimaryBrush}"/>
                                                            <TextBlock Grid.Column="3" Text="{Binding TotalTimeFormatted}" Style="{StaticResource LiveRowTextStyle}" TextAlignment="Center"/>
                                                            <TextBlock Grid.Column="4" Text="{Binding AvgTimeFormatted}" Style="{StaticResource LiveRowTextStyle}" TextAlignment="Center"/>
                                                        </Grid>
                                                    </Border>
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>
                                    </StackPanel>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>

                    <!-- No data fallback -->
                    <TextBlock Text="No data available" Foreground="#AAAAAA" FontSize="12" FontFamily="{StaticResource MainFontFamily}" HorizontalAlignment="Center" Margin="0,20,0,10">
                        <TextBlock.Style>
                            <Style TargetType="TextBlock">
                                <Setter Property="Visibility" Value="Collapsed"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding ProductivityTab.EmployeeCategoryGroups.Count}" Value="0">
                                        <Setter Property="Visibility" Value="Visible"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBlock.Style>
                    </TextBlock>
                </StackPanel>

                <!-- QC TEAM Section -->
                <StackPanel Grid.Column="2">
                    <!-- Section Header -->
                    <Grid Margin="0,0,0,12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0" Orientation="Horizontal">
                            <TextBlock Text="&#xE73E;" FontFamily="Segoe MDL2 Assets" FontSize="16" Foreground="#34C759" VerticalAlignment="Center" Margin="0,0,8,0"/>
                            <TextBlock Text="QC TEAM" Style="{StaticResource LiveSectionTitleStyle}"/>
                        </StackPanel>
                        <Border Grid.Column="2" Background="#E8F8EF" CornerRadius="6" Padding="8,4">
                            <TextBlock Text="Quality Control" Style="{StaticResource LiveSectionBadgeStyle}" Foreground="#34C759"/>
                        </Border>
                    </Grid>

                    <!-- Each category = separate card box -->
                    <ItemsControl ItemsSource="{Binding ProductivityTab.QcCategoryGroups}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Background="{DynamicResource BgCardBrush}" CornerRadius="10" Padding="14,12" Margin="0,0,0,10" SnapsToDevicePixels="True">
                                    <Border.Effect>
                                        <DropShadowEffect ShadowDepth="1" BlurRadius="4" Opacity="0.06" Color="#000000"/>
                                    </Border.Effect>
                                    <StackPanel>
                                        <!-- Category name header -->
                                        <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                                            <Ellipse Width="8" Height="8" Fill="#34C759" VerticalAlignment="Center" Margin="0,0,8,0"/>
                                            <TextBlock Text="{Binding CategoryDisplay}" Style="{StaticResource LiveCategoryNameStyle}"/>
                                        </StackPanel>

                                        <!-- Column headers -->
                                        <Grid Margin="4,0,0,4">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="34"/>
                                                <ColumnDefinition Width="2.2*"/>
                                                <ColumnDefinition Width="0.8*"/>
                                                <ColumnDefinition Width="1.2*"/>
                                                <ColumnDefinition Width="1*"/>
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Grid.Column="0" Text="#" Style="{StaticResource LiveGridHeaderTextStyle}" TextAlignment="Center"/>
                                            <TextBlock Grid.Column="1" Text="EMPLOYEE" Style="{StaticResource LiveGridHeaderTextStyle}"/>
                                            <TextBlock Grid.Column="2" Text="FILES" Style="{StaticResource LiveGridHeaderTextStyle}" TextAlignment="Center"/>
                                            <TextBlock Grid.Column="3" Text="TOTAL TIME" Style="{StaticResource LiveGridHeaderTextStyle}" TextAlignment="Center"/>
                                            <TextBlock Grid.Column="4" Text="AVG TIME" Style="{StaticResource LiveGridHeaderTextStyle}" TextAlignment="Center"/>
                                        </Grid>

                                        <!-- QC Employee rows (ranked: most files first) -->
                                        <ItemsControl ItemsSource="{Binding Employees}" AlternationCount="1000000">
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate>
                                                    <Border Padding="4,7" BorderBrush="Transparent" BorderThickness="1" CornerRadius="6" Background="Transparent" Margin="0,1,0,0">
                                                        <Border.Style>
                                                            <Style TargetType="Border">
                                                                <Style.Triggers>
                                                                    <Trigger Property="IsMouseOver" Value="True">
                                                                        <Setter Property="BorderBrush" Value="{DynamicResource PrimaryBrush}"/>
                                                                    </Trigger>
                                                                </Style.Triggers>
                                                            </Style>
                                                        </Border.Style>
                                                        <Grid>
                                                            <Grid.ColumnDefinitions>
                                                                <ColumnDefinition Width="34"/>
                                                                <ColumnDefinition Width="2.2*"/>
                                                                <ColumnDefinition Width="0.8*"/>
                                                                <ColumnDefinition Width="1.2*"/>
                                                                <ColumnDefinition Width="1*"/>
                                                            </Grid.ColumnDefinitions>
                                                            <TextBlock Grid.Column="0" TextAlignment="Center" Style="{StaticResource LiveRowTextStyle}" Foreground="{DynamicResource TextSecondaryBrush}"
                                                                       Text="{Binding RelativeSource={RelativeSource AncestorType=ContentPresenter}, Path=(ItemsControl.AlternationIndex), Converter={StaticResource AlternationIndexToOneBasedConverter}}"/>
                                                            <TextBlock Grid.Column="1" Text="{Binding EmployeeNameDisplay}" Style="{StaticResource LiveRowBoldTextStyle}"/>
                                                            <TextBlock Grid.Column="2" Text="{Binding TotalFiles}" Style="{StaticResource LiveRowTextStyle}" TextAlignment="Center" FontWeight="SemiBold" Foreground="{DynamicResource PrimaryBrush}"/>
                                                            <TextBlock Grid.Column="3" Text="{Binding TotalTimeFormatted}" Style="{StaticResource LiveRowTextStyle}" TextAlignment="Center"/>
                                                            <TextBlock Grid.Column="4" Text="{Binding AvgTimeFormatted}" Style="{StaticResource LiveRowTextStyle}" TextAlignment="Center"/>
                                                        </Grid>
                                                    </Border>
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>
                                    </StackPanel>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>

                    <!-- No data fallback -->
                    <TextBlock Text="No data available" Foreground="#AAAAAA" FontSize="12" FontFamily="{StaticResource MainFontFamily}" HorizontalAlignment="Center" Margin="0,20,0,10">
                        <TextBlock.Style>
                            <Style TargetType="TextBlock">
                                <Setter Property="Visibility" Value="Collapsed"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding ProductivityTab.QcCategoryGroups.Count}" Value="0">
                                        <Setter Property="Visibility" Value="Visible"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBlock.Style>
                    </TextBlock>
                </StackPanel>
            </Grid>
        </StackPanel>
    </ScrollViewer>
</UserControl>
