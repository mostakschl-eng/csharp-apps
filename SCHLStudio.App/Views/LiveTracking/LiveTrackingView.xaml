<UserControl x:Class="SCHLStudio.App.Views.LiveTracking.LiveTrackingView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:tabs="clr-namespace:SCHLStudio.App.Views.LiveTracking.Tabs"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             mc:Ignorable="d"
             d:DesignHeight="800" d:DesignWidth="1200"
             Background="{DynamicResource BgMainBrush}">

    <UserControl.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="/SCHLStudio.App;component/Views/LiveTracking/Shared/LiveTrackingStyles.xaml" />
            </ResourceDictionary.MergedDictionaries>

        <Style x:Key="LiveTrackingTabItemStyle" TargetType="TabItem">
            <Setter Property="Foreground" Value="{DynamicResource TextMainBrush}" />
            <Setter Property="FontFamily" Value="{StaticResource MainFontFamily}" />
            <Setter Property="FontSize" Value="12" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Padding" Value="16,9" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TabItem">
                        <Border x:Name="HeaderBorder"
                                Background="Transparent"
                                BorderBrush="Transparent"
                                BorderThickness="1"
                                CornerRadius="10"
                                Padding="{TemplateBinding Padding}"
                                Margin="0,0,8,0">
                            <ContentPresenter ContentSource="Header"
                                              VerticalAlignment="Center"
                                              HorizontalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="HeaderBorder" Property="Background" Value="{DynamicResource BgCardHoverBrush}" />
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="HeaderBorder" Property="Background" Value="{DynamicResource BgCardBrush}" />
                                <Setter TargetName="HeaderBorder" Property="BorderBrush" Value="{DynamicResource PrimaryBrush}" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="LiveTrackingTabControlStyle" TargetType="TabControl">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Padding" Value="0" />
        </Style>

        </ResourceDictionary>
    </UserControl.Resources>

    <Grid Background="{DynamicResource BgMainBrush}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>   <!-- Header row: title + filters -->
            <RowDefinition Height="*"/>      <!-- Tab control -->
        </Grid.RowDefinitions>

        <!-- Row 0: Title (left) + Filters (right) in one row -->
        <Grid Grid.Row="0" Margin="24,20,24,6">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <!-- Live pulse icon + title -->
            <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                <Ellipse Width="10" Height="10" Fill="#34C759" Margin="0,0,8,0" VerticalAlignment="Center"/>
                <TextBlock Text="LIVE TRACKING"
                           Foreground="{DynamicResource TextMainBrush}"
                           FontFamily="{StaticResource MainFontFamily}"
                           FontSize="18" FontWeight="Bold"
                           VerticalAlignment="Center" />
            </StackPanel>

            <!-- 3 filter buttons: Date, Client, User — all same rounded style -->
            <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center">

                <!-- Client -->
                <Border Background="{DynamicResource BgCardBrush}"
                        BorderBrush="{DynamicResource BorderLightBrush}"
                        BorderThickness="1" CornerRadius="10"
                        Padding="4,0" Height="32" Margin="0,0,10,0">
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <TextBlock Text="&#xE77B;" FontFamily="Segoe MDL2 Assets" FontSize="13"
                                   Foreground="{DynamicResource PrimaryBrush}" VerticalAlignment="Center" Margin="6,0,4,0"/>
                        <ComboBox ItemsSource="{Binding AvailableClients}"
                                  SelectedItem="{Binding SelectedClient, Mode=TwoWay}"
                                  Style="{StaticResource LiveFilterComboStyle}"
                                  MinWidth="120" Height="30"
                                  BorderThickness="0" Background="Transparent"
                                  Padding="4,5"/>
                    </StackPanel>
                </Border>

                <!-- User -->
                <Border Background="{DynamicResource BgCardBrush}"
                        BorderBrush="{DynamicResource BorderLightBrush}"
                        BorderThickness="1" CornerRadius="10"
                        Padding="4,0" Height="32" Margin="0,0,10,0">
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <TextBlock Text="&#xE716;" FontFamily="Segoe MDL2 Assets" FontSize="13"
                                   Foreground="{DynamicResource PrimaryBrush}" VerticalAlignment="Center" Margin="6,0,4,0"/>
                        <ComboBox ItemsSource="{Binding AvailableUsers}"
                                  SelectedItem="{Binding SelectedUser, Mode=TwoWay}"
                                  Style="{StaticResource LiveFilterComboStyle}"
                                  MinWidth="120" Height="30"
                                  BorderThickness="0" Background="Transparent"
                                  Padding="4,5"/>
                    </StackPanel>
                </Border>

                <!-- Shift -->
                <Border Background="{DynamicResource BgCardBrush}"
                        BorderBrush="{DynamicResource BorderLightBrush}"
                        BorderThickness="1" CornerRadius="10"
                        Padding="4,0" Height="32" Margin="0,0,10,0">
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <TextBlock Text="&#xE121;" FontFamily="Segoe MDL2 Assets" FontSize="13"
                                   Foreground="{DynamicResource PrimaryBrush}" VerticalAlignment="Center" Margin="6,0,4,0"/>
                        <ComboBox ItemsSource="{Binding AvailableShifts}"
                                  SelectedItem="{Binding SelectedShift, Mode=TwoWay}"
                                  Style="{StaticResource LiveFilterComboStyle}"
                                  MinWidth="110" Height="30"
                                  BorderThickness="0" Background="Transparent"
                                  Padding="4,5"/>
                    </StackPanel>
                </Border>

            </StackPanel>
        </Grid>

        <!-- Row 1: Tabs with generous top padding to separate from header -->
        <TabControl Grid.Row="1"
                    Margin="24,10,24,20"
                    Style="{StaticResource LiveTrackingTabControlStyle}"
                    ItemContainerStyle="{StaticResource LiveTrackingTabItemStyle}">
            <TabControl.Resources>
                <!-- THIS is the gap between tab headers and tab content (summary cards) -->
                <Style TargetType="TabPanel">
                    <Setter Property="Margin" Value="0,0,0,20" />
                </Style>
            </TabControl.Resources>

            <TabItem Header="CLIENT">
                <tabs:ClientTabView />
            </TabItem>
            <TabItem Header="PRODUCTION">
                <tabs:ProductionTabView />
            </TabItem>
            <TabItem Header="QC">
                <tabs:QcTabView />
            </TabItem>
            <TabItem Header="ACTIVITY">
                <tabs:PauseTabView />
            </TabItem>
            <TabItem Header="IDLE">
                <tabs:IdleTabView />
            </TabItem>
            <TabItem Header="USER SUMMARY">
                <tabs:UserSummaryTabView />
            </TabItem>
            <TabItem Header="PRODUCTIVITY">
                <tabs:ProductivityTabView />
            </TabItem>
        </TabControl>
    </Grid>
</UserControl>
